package com.fullpack.panictrader.core

import kotlin.math.abs

/**
 * ADX (Average Directional Index) 3rd Gate Filter.
 *
 * Rules:
 * - ADX >= 25 required for any entry.
 * - BUY allowed only if +DI > -DI.
 * - SELL allowed only if -DI > +DI.
 */
enum class AdxGateDecision { ALLOW_LONG, ALLOW_SHORT, HOLD }

data class AdxMetrics(
    val adx: Double,
    val plusDi: Double,
    val minusDi: Double,
    val isValid: Boolean
)

object AdxThirdGate {

    /**
     * Computes Wilder's ADX(14).
     * Requires at least (period * 2 + 1) candles for a basic calculation, 
     * but more (e.g. 50-100) are better for stabilization.
     */
    fun compute(candles: List<Candle>, period: Int = 14): AdxMetrics {
        if (candles.size < period * 2 + 1) {
            return AdxMetrics(0.0, 0.0, 0.0, false)
        }

        val trs = mutableListOf<Double>()
        val plusDMs = mutableListOf<Double>()
        val minusDMs = mutableListOf<Double>()

        for (i in 1 until candles.size) {
            val curr = candles[i]
            val prev = candles[i - 1]

            // 1. True Range
            val tr = maxOf(
                curr.high - curr.low,
                abs(curr.high - prev.close),
                abs(curr.low - prev.close)
            )
            trs.add(tr)

            // 2. Directional Movement
            val upMove = curr.high - prev.high
            val downMove = prev.low - curr.low

            val plusDM = if (upMove > downMove && upMove > 0) upMove else 0.0
            val minusDM = if (downMove > upMove && downMove > 0) downMove else 0.0

            plusDMs.add(plusDM)
            minusDMs.add(minusDM)
        }

        // Wilder Smoothing (RMA)
        // alpha = 1 / period
        val alpha = 1.0 / period

        fun rma(data: List<Double>): DoubleArray {
            val smoothed = DoubleArray(data.size)
            if (data.isEmpty()) return smoothed
            
            var sum = 0.0
            for (i in 0 until period) {
                sum += data[i]
            }
            smoothed[period - 1] = sum / period

            for (i in period until data.size) {
                smoothed[i] = (data[i] - smoothed[i - 1]) * alpha + smoothed[i - 1]
            }
            return smoothed
        }

        val smoothedTR = rma(trs)
        val smoothedPlusDM = rma(plusDMs)
        val smoothedMinusDM = rma(minusDMs)

        val plusDIs = DoubleArray(trs.size)
        val minusDIs = DoubleArray(trs.size)
        val dxs = DoubleArray(trs.size)

        for (i in period - 1 until trs.size) {
            val trVal = if (smoothedTR[i] == 0.0) 1e-9 else smoothedTR[i]
            plusDIs[i] = 100.0 * (smoothedPlusDM[i] / trVal)
            minusDIs[i] = 100.0 * (smoothedMinusDM[i] / trVal)

            val diSum = plusDIs[i] + minusDIs[i]
            val diDiff = abs(plusDIs[i] - minusDIs[i])
            dxs[i] = if (diSum == 0.0) 0.0 else 100.0 * (diDiff / diSum)
        }

        // Final ADX is the RMA of DX
        // ADX needs period candles of DX starting from the first valid DX at period-1
        // So we need index (period - 1) + (period - 1) = 2 * period - 2 minimum
        if (trs.size < 2 * period - 1) {
            return AdxMetrics(0.0, plusDIs.last(), minusDIs.last(), false)
        }

        val adxStartIdx = 2 * period - 2
        var adxSum = 0.0
        for (i in period - 1..adxStartIdx) {
            adxSum += dxs[i]
        }
        
        var currentAdx = adxSum / period
        for (i in adxStartIdx + 1 until trs.size) {
            currentAdx = (dxs[i] - currentAdx) * alpha + currentAdx
        }

        return AdxMetrics(currentAdx, plusDIs.last(), minusDIs.last(), true)
    }

    /**
     * Evaluates ADX trend strength and direction.
     */
    fun filter(proposedDecision: TradeDecision, candles: List<Candle>, adxThreshold: Double = 25.0): AdxGateDecision {
        if (proposedDecision == TradeDecision.HOLD) return AdxGateDecision.HOLD

        val metrics = compute(candles)
        if (!metrics.isValid) return AdxGateDecision.HOLD
        if (metrics.adx < adxThreshold) return AdxGateDecision.HOLD

        return when (proposedDecision) {
            TradeDecision.BUY -> {
                if (metrics.plusDi > metrics.minusDi) AdxGateDecision.ALLOW_LONG else AdxGateDecision.HOLD
            }
            TradeDecision.SELL -> {
                if (metrics.minusDi > metrics.plusDi) AdxGateDecision.ALLOW_SHORT else AdxGateDecision.HOLD
            }
            else -> AdxGateDecision.HOLD
        }
    }
}







package com.fullpack.panictrader.core

import kotlinx.coroutines.Dispatchers
import kotlinx.coroutines.delay
import kotlinx.coroutines.withContext
import kotlinx.serialization.Serializable
import kotlinx.serialization.json.Json
import okhttp3.HttpUrl
import okhttp3.HttpUrl.Companion.toHttpUrlOrNull
import okhttp3.MediaType.Companion.toMediaTypeOrNull
import okhttp3.OkHttpClient
import okhttp3.Request
import okhttp3.RequestBody.Companion.toRequestBody
import okhttp3.logging.HttpLoggingInterceptor
import java.math.BigDecimal
import java.math.RoundingMode
import java.nio.charset.StandardCharsets
import java.util.UUID
import javax.crypto.Mac
import javax.crypto.spec.SecretKeySpec

enum class BybitEnv(val baseUrl: String) {
    PROD("https://api.bybit.com"),
    DEMO("https://api-demo.bybit.com")
}

enum class Side { BUY, SELL }

@Serializable
data class KlineResp(
    val retCode: Int,
    val retMsg: String,
    val result: KlineResult? = null
)

@Serializable
data class KlineResult(
    val list: List<List<String>> = emptyList()
)

@Serializable
data class WalletBalanceResp(
    val retCode: Int,
    val retMsg: String,
    val result: WalletBalanceResult? = null
)

@Serializable
data class WalletBalanceResult(
    val list: List<WalletBalanceInfo> = emptyList()
)

@Serializable
data class WalletBalanceInfo(
    val totalWalletBalance: String? = null,
    val coin: List<CoinBalance>? = null
)

@Serializable
data class CoinBalance(
    val coin: String,
    val walletBalance: String? = null,
    val availableToWithdraw: String? = null
)

@Serializable
data class PositionInfoResp(
    val retCode: Int,
    val retMsg: String,
    val result: PositionInfoResult? = null
)

@Serializable
data class PositionInfoResult(
    val list: List<PositionItem> = emptyList()
)

@Serializable
data class PositionItem(
    val symbol: String,
    val side: String,
    val size: String,
    val avgPrice: String? = null,
    val unrealisedPnl: String? = null
)

data class Candle(
    val startTimeMs: Long,
    val open: Double,
    val high: Double,
    val low: Double,
    val close: Double,
    val volume: Double
)

class BybitApi(
    private val env: BybitEnv,
    private val apiKey: String,
    private val apiSecret: String
) {
    private val json = Json { ignoreUnknownKeys = true }

    private val client: OkHttpClient = OkHttpClient.Builder()
        .addInterceptor(HttpLoggingInterceptor().apply { level = HttpLoggingInterceptor.Level.BASIC })
        .build()

    private fun round(value: Double, scale: Int): String {
        return BigDecimal(value.toString())
            .setScale(scale, RoundingMode.DOWN)
            .toPlainString()
    }

    suspend fun getKlines(symbol: String, interval: String, limit: Int = 300): List<Candle> =
        withContext(Dispatchers.IO) {

            val url = "${env.baseUrl}/v5/market/kline".toHttpUrlOrNull()!!.newBuilder()
                .addQueryParameter("category", "linear")
                .addQueryParameter("symbol", symbol)
                .addQueryParameter("interval", interval)
                .addQueryParameter("limit", limit.toString())
                .build()

            val req = Request.Builder().url(url).get().build()
            val body = executeWithRetry(req)

            val resp = json.decodeFromString(KlineResp.serializer(), body)
            if (resp.retCode != 0) error("kline retCode=${resp.retCode} msg=${resp.retMsg}")

            val rows = resp.result?.list ?: emptyList()
            rows.mapNotNull { r ->
                if (r.size < 6) return@mapNotNull null
                val t = r[0].toLongOrNull() ?: return@mapNotNull null
                Candle(
                    startTimeMs = t,
                    open = r[1].toDoubleOrNull() ?: return@mapNotNull null,
                    high = r[2].toDoubleOrNull() ?: return@mapNotNull null,
                    low = r[3].toDoubleOrNull() ?: return@mapNotNull null,
                    close = r[4].toDoubleOrNull() ?: return@mapNotNull null,
                    volume = r[5].toDoubleOrNull() ?: 0.0
                )
            }.sortedBy { it.startTimeMs }
        }

    suspend fun setLeverage(symbol: String, lev: Double): String = withContext(Dispatchers.IO) {
        val bodyJson = """
            {
              "category":"linear",
              "symbol":"$symbol",
              "buyLeverage":"$lev",
              "sellLeverage":"$lev"
            }
        """.trimIndent()

        val req = signedPost("/v5/position/set-leverage", bodyJson)
        executeWithRetry(req)
    }

    suspend fun getWalletBalanceUsdt(): Double = withContext(Dispatchers.IO) {
        val url = "${env.baseUrl}/v5/account/wallet-balance".toHttpUrlOrNull()!!.newBuilder()
            .addQueryParameter("accountType", "UNIFIED")
            .addQueryParameter("coin", "USDT")
            .build()

        val req = signedGet(url)
        val raw = executeWithRetry(req)

        val resp = json.decodeFromString(WalletBalanceResp.serializer(), raw)
        if (resp.retCode != 0) error("Wallet balance retCode=${resp.retCode} msg=${resp.retMsg}")

        val accountInfo = resp.result?.list?.firstOrNull()
            ?: error("No account info found in wallet balance response")

        // Try to get available USDT specifically
        val usdtCoin = accountInfo.coin?.find { it.coin == "USDT" }
        val bal = usdtCoin?.availableToWithdraw?.toDoubleOrNull() 
                  ?: usdtCoin?.walletBalance?.toDoubleOrNull()
                  ?: accountInfo.totalWalletBalance?.toDoubleOrNull()
                  ?: error("Cannot parse balance. Raw=$raw")
        
        bal
    }

    suspend fun getOpenPositionInfo(symbol: String): PositionItem? = withContext(Dispatchers.IO) {
        val url = "${env.baseUrl}/v5/position/list".toHttpUrlOrNull()!!.newBuilder()
            .addQueryParameter("category", "linear")
            .addQueryParameter("symbol", symbol)
            .build()

        val req = signedGet(url)
        val raw = executeWithRetry(req)

        val resp = json.decodeFromString(PositionInfoResp.serializer(), raw)
        if (resp.retCode != 0) error("Position info retCode=${resp.retCode} msg=${resp.retMsg}")

        val pos = resp.result?.list?.firstOrNull()
        if (pos != null && (pos.size.toDoubleOrNull() ?: 0.0) > 0.0) pos else null
    }

    suspend fun placeMarketOrder(
        symbol: String,
        side: Side,
        qty: Double,
        takeProfitPrice: Double?,
        stopLossPrice: Double?,
        reduceOnly: Boolean = false
    ): String = withContext(Dispatchers.IO) {

        val q = round(qty, 3)
        val tp = takeProfitPrice?.let { "\"takeProfit\":\"${round(it, 1)}\"," } ?: ""
        val sl = stopLossPrice?.let { "\"stopLoss\":\"${round(it, 1)}\"," } ?: ""
        val ro = if (reduceOnly) "\"reduceOnly\":true," else ""

        val bodyJson = """
            {
              "category":"linear",
              "symbol":"$symbol",
              "side":"${if (side == Side.BUY) "Buy" else "Sell"}",
              "orderType":"Market",
              "qty":"$q",
              $tp
              $sl
              $ro
              "timeInForce":"IOC"
            }
        """.trimIndent()

        val req = signedPost("/v5/order/create", bodyJson)
        executeWithRetry(req)
    }

    suspend fun transferUtaToFunding(amount: Double): String = withContext(Dispatchers.IO) {
        val transferId = UUID.randomUUID().toString()
        val amountStr = round(amount, 4)
        val bodyJson = """
            {
              "transferId":"$transferId",
              "coin":"USDT",
              "amount":"$amountStr",
              "fromAccountType":"UNIFIED",
              "toAccountType":"FUND"
            }
        """.trimIndent()

        val req = signedPost("/v5/asset/transfer/inter-transfer", bodyJson)
        executeWithRetry(req)
    }

    private fun signedGet(url: HttpUrl): Request {
        val ts = System.currentTimeMillis().toString()
        val recvWindow = "20000"
        val query = url.query ?: ""
        val prehash = ts + apiKey + recvWindow + query
        val sign = hmacSha256Hex(apiSecret, prehash)

        return Request.Builder()
            .url(url)
            .get()
            .header("X-BAPI-API-KEY", apiKey)
            .header("X-BAPI-SIGN", sign)
            .header("X-BAPI-SIGN-TYPE", "2")
            .header("X-BAPI-TIMESTAMP", ts)
            .header("X-BAPI-RECV-WINDOW", recvWindow)
            .build()
    }

    private fun signedPost(path: String, bodyJson: String): Request {
        val ts = System.currentTimeMillis().toString()
        val recvWindow = "20000"
        val cleanBody = bodyJson.replace(Regex("\\s+"), "")
        val prehash = ts + apiKey + recvWindow + cleanBody
        val sign = hmacSha256Hex(apiSecret, prehash)

        val body = cleanBody.toRequestBody("application/json".toMediaTypeOrNull())
        return Request.Builder()
            .url(env.baseUrl + path)
            .post(body)
            .header("Content-Type", "application/json")
            .header("X-BAPI-API-KEY", apiKey)
            .header("X-BAPI-SIGN", sign)
            .header("X-BAPI-SIGN-TYPE", "2")
            .header("X-BAPI-TIMESTAMP", ts)
            .header("X-BAPI-RECV-WINDOW", recvWindow)
            .build()
    }

    private fun hmacSha256Hex(secret: String, msg: String): String {
        val mac = Mac.getInstance("HmacSHA256")
        mac.init(SecretKeySpec(secret.toByteArray(StandardCharsets.UTF_8), "HmacSHA256"))
        val out = mac.doFinal(msg.toByteArray(StandardCharsets.UTF_8))
        return out.joinToString("") { "%02x".format(it) }
    }

    private suspend fun executeWithRetry(req: Request): String = withContext(Dispatchers.IO) {
        var attempt = 0
        var backoff = 500L
        var lastErr: Throwable? = null

        while (attempt < 6) {
            attempt++
            try {
                client.newCall(req).execute().use { resp ->
                    val body = resp.body?.string().orEmpty()

                    if (resp.isSuccessful) {
                        return@withContext body
                    }

                    val code = resp.code
                    if (code == 429 || code in 500..599) {
                        lastErr = RuntimeException("HTTP $code body=$body")
                    } else {
                        throw RuntimeException("HTTP $code body=$body")
                    }
                }
            } catch (t: Throwable) {
                lastErr = t
            }

            delay(backoff)
            backoff = (backoff * 2).coerceAtMost(8000L)
        }

        throw RuntimeException("Request failed after retries: ${lastErr?.message}", lastErr)
    }
}







