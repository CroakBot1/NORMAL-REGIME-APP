package com.fullpack.panictrader.core

import org.junit.Assert.*
import org.junit.Test

class AdxThirdGateTest {

    private fun createCandle(h: Double, l: Double, c: Double) = Candle(
        startTimeMs = 0, open = c, high = h, low = l, close = c, volume = 0.0
    )

    @Test
    fun testInsufficientCandles() {
        val candles = List(10) { createCandle(100.0, 90.0, 95.0) }
        val metrics = AdxThirdGate.compute(candles)
        assertFalse("Metrics should be invalid with few candles", metrics.isValid)
    }

    @Test
    fun testFilterHoldStaysHold() {
        val candles = List(40) { createCandle(100.0, 90.0, 95.0) }
        val result = AdxThirdGate.filter(TradeDecision.HOLD, candles)
        assertEquals(AdxGateDecision.HOLD, result)
    }

    @Test
    fun testStrongTrendDetection() {
        // Create a synthetic strong upward trend to trigger ADX > 25 and +DI > -DI
        val candles = mutableListOf<Candle>()
        var price = 100.0
        for (i in 0 until 60) {
            price += 2.0
            candles.add(createCandle(price + 1.0, price - 1.0, price))
        }
        
        val metrics = AdxThirdGate.compute(candles)
        assertTrue("ADX should be valid", metrics.isValid)
        assertTrue("ADX should be significant (>25) in strong trend, got ${metrics.adx}", metrics.adx > 25.0)
        assertTrue("+DI should be > -DI in uptrend", metrics.plusDi > metrics.minusDi)
        
        val filterResult = AdxThirdGate.filter(TradeDecision.BUY, candles)
        assertEquals(AdxGateDecision.ALLOW_LONG, filterResult)
    }

    @Test
    fun testRangingMarketBlocks() {
        // Constant price should lead to low ADX
        val candles = List(60) { createCandle(105.0, 95.0, 100.0) }
        val metrics = AdxThirdGate.compute(candles)
        
        if (metrics.isValid) {
            assertTrue("ADX should be low in ranging market, got ${metrics.adx}", metrics.adx < 25.0)
            val filterResult = AdxThirdGate.filter(TradeDecision.BUY, candles)
            assertEquals(AdxGateDecision.HOLD, filterResult)
        }
    }
}






package com.fullpack.panictrader.core

import org.junit.Assert.assertEquals
import org.junit.Test

class MarketStructureGateTest {

    private fun createCandle(high: Double, low: Double, close: Double): Candle {
        return Candle(0L, 0.0, high, low, close, 0.0)
    }

    /**
     * Helper to create a series of candles that form a specific structure.
     * Bullish HH/HL: 
     * SL1: (L=90), SH1: (H=110), SL2: (L=95), SH2: (H=115)
     */
    private fun getBullishCandles(): List<Candle> {
        // Needs pivotSize=2, so each pivot needs 2 candles left and 2 right.
        return listOf(
            createCandle(100.0, 95.0, 98.0),
            createCandle(100.0, 92.0, 96.0),
            createCandle(95.0, 90.0, 92.0), // SL1 at index 2 (Low 90)
            createCandle(105.0, 95.0, 100.0),
            createCandle(108.0, 98.0, 102.0),
            createCandle(110.0, 100.0, 105.0), // SH1 at index 5 (High 110)
            createCandle(105.0, 98.0, 100.0),
            createCandle(102.0, 96.0, 98.0),
            createCandle(100.0, 95.0, 97.0), // SL2 at index 8 (Low 95)
            createCandle(110.0, 100.0, 105.0),
            createCandle(112.0, 105.0, 108.0),
            createCandle(115.0, 108.0, 110.0), // SH2 at index 11 (High 115)
            createCandle(112.0, 108.0, 110.0),
            createCandle(110.0, 105.0, 108.0) // Current Close 108
        )
    }

    private fun getBearishCandles(): List<Candle> {
        return listOf(
            createCandle(110.0, 105.0, 108.0),
            createCandle(112.0, 108.0, 110.0),
            createCandle(115.0, 110.0, 112.0), // SH1 (High 115)
            createCandle(105.0, 100.0, 102.0),
            createCandle(102.0, 98.0, 100.0),
            createCandle(100.0, 95.0, 97.0),  // SL1 (Low 95)
            createCandle(108.0, 102.0, 105.0),
            createCandle(110.0, 104.0, 107.0),
            createCandle(112.0, 106.0, 108.0), // SH2 (High 112) -> LH
            createCandle(100.0, 92.0, 95.0),
            createCandle(98.0, 90.0, 94.0),
            createCandle(95.0, 85.0, 90.0),  // SL2 (Low 85) -> LL
            createCandle(98.0, 88.0, 92.0),
            createCandle(100.0, 90.0, 95.0)  // Current Close 95
        )
    }

    @Test
    fun testInsufficientCandlesFailClosed() {
        val candles = listOf(createCandle(100.0, 90.0, 95.0))
        val gate = MarketStructureGate(TradeDecision.BUY, candles)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }

    @Test
    fun testBuyPassesOnBullish() {
        val candles = getBullishCandles() 
        // Current Close 108, Last SH 115. distH = (115-108)/108 = 0.0648 > 0.002
        val gate = MarketStructureGate(TradeDecision.BUY, candles)
        assertEquals(TradeDecision.BUY, gate.filter())
    }

    @Test
    fun testSellPassesOnBearish() {
        val candles = getBearishCandles()
        // Current Close 95, Last SL 85. distL = (95-85)/95 = 0.105 > 0.002
        val gate = MarketStructureGate(TradeDecision.SELL, candles)
        assertEquals(TradeDecision.SELL, gate.filter())
    }

    @Test
    fun testBuyBlocksOnBearish() {
        val candles = getBearishCandles()
        val gate = MarketStructureGate(TradeDecision.BUY, candles)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }

    @Test
    fun testSellBlocksOnBullish() {
        val candles = getBullishCandles()
        val gate = MarketStructureGate(TradeDecision.SELL, candles)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }

    @Test
    fun testBuyBlocksOnBOSUp() {
        val base = getBullishCandles().toMutableList()
        // Last SH was 115. Push price to 116.
        base.add(createCandle(118.0, 114.0, 116.0))
        base.add(createCandle(117.0, 115.0, 116.0))
        base.add(createCandle(117.0, 115.0, 116.0)) // Need to keep it as confirmed pivot
        
        val gate = MarketStructureGate(TradeDecision.BUY, base)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }

    @Test
    fun testBuyBlocksNearSwingHigh() {
        val base = getBullishCandles().toMutableList()
        // Last SH was 115. Put close at 114.9
        // distH = (115 - 114.9) / 114.9 = 0.00087 < 0.002
        base.add(createCandle(115.0, 114.0, 114.9))
        base.add(createCandle(115.0, 114.0, 114.9))
        
        val gate = MarketStructureGate(TradeDecision.BUY, base)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }

    @Test
    fun testHoldStaysHold() {
        val candles = getBullishCandles()
        val gate = MarketStructureGate(TradeDecision.HOLD, candles)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }
}







package com.fullpack.panictrader.core

import org.junit.Assert.assertEquals
import org.junit.Test

class MarketStructureTest {

    private fun createCandle(h: Double, l: Double, c: Double) = Candle(
        startTimeMs = 0, open = c, high = h, low = l, close = c, volume = 0.0
    )

    @Test
    fun testInsufficientCandles() {
        val candles = listOf(createCandle(100.0, 90.0, 95.0))
        val decision = TradeDecision.BUY
        val gate = MarketStructureGate(decision, candles)
        assertEquals(TradeDecision.HOLD, gate.filter())
    }

    @Test
    fun testBullishStructureConfirmation() {
        // Higher Highs and Higher Lows
        // Pivot 2 needs at least 5 candles to form a pivot.
        // SH1 at 110, SH2 at 105. SL1 at 95, SL2 at 90.
        val candles = listOf(
            createCandle(100.0, 80.0, 90.0),  // 0
            createCandle(102.0, 85.0, 95.0),  // 1
            createCandle(105.0, 90.0, 100.0), // 2: SH2 (pivot 2)
            createCandle(103.0, 88.0, 98.0),  // 3
            createCandle(101.0, 86.0, 96.0),  // 4
            createCandle(104.0, 92.0, 97.0),  // 5
            createCandle(108.0, 94.0, 100.0), // 6
            createCandle(110.0, 96.0, 105.0), // 7: SH1
            createCandle(109.0, 95.0, 104.0), // 8
            createCandle(107.0, 93.0, 102.0), // 9
            createCandle(106.0, 92.0, 103.0)  // 10: current close 103
        )
        // SH1=110, SH2=105 -> HH
        // SL? Let's check SLs. 
        // Candle 2 High is 105. Neighbors (0,1) and (3,4) are lower. Correct.
        // Candle 7 High is 110. Neighbors (5,6) and (8,9) are lower. Correct.
        
        // SL2 at index 0? No, needs 2 neighbors.
        // Let's add more for SLs.
        val bullishCandles = listOf(
            createCandle(90.0, 70.0, 80.0),   // -2
            createCandle(92.0, 75.0, 85.0),   // -1
            createCandle(95.0, 80.0, 90.0),   // 0
            createCandle(93.0, 78.0, 88.0),   // 1
            createCandle(94.0, 82.0, 89.0),   // 2: SL2=78? No, low at 1 is 78. Neighbors 0, -1 are higher. 2,3 are higher. Correct.
            createCandle(105.0, 90.0, 100.0), // 3: SH2=105
            createCandle(100.0, 85.0, 95.0),  // 4
            createCandle(102.0, 88.0, 96.0),  // 5
            createCandle(101.0, 84.0, 92.0),  // 6: SL1=84. Neighbors 4,5 and 7,8?
            createCandle(103.0, 86.0, 94.0),  // 7
            createCandle(104.0, 87.0, 95.0),  // 8
            createCandle(110.0, 95.0, 105.0), // 9: SH1=110
            createCandle(108.0, 94.0, 104.0), // 10
            createCandle(107.0, 93.0, 103.0), // 11
            createCandle(106.0, 92.0, 104.0)  // 12: close 104. distToSH=(110-104)/104 = 0.057 > 0.002
        )
        // SH1=110, SH2=105 (HH). SL1=84, SL2=78 (HL). Bullish.
        
        val decision = TradeDecision.BUY
        val gate = MarketStructureGate(decision, bullishCandles)
        assertEquals(TradeDecision.BUY, gate.filter())
    }

    @Test
    fun testBearishStructureConfirmation() {
        val bearishCandles = listOf(
            createCandle(120.0, 100.0, 110.0), // -2
            createCandle(118.0, 105.0, 112.0), // -1
            createCandle(115.0, 100.0, 110.0), // 0: SH2=120? No.
            createCandle(125.0, 110.0, 115.0), // 1
            createCandle(130.0, 115.0, 120.0), // 2: SH2=130
            createCandle(128.0, 112.0, 118.0), // 3
            createCandle(127.0, 111.0, 116.0), // 4
            createCandle(115.0, 105.0, 110.0), // 5
            createCandle(110.0, 90.0, 100.0),  // 6: SL2=90
            createCandle(112.0, 95.0, 102.0),  // 7
            createCandle(113.0, 96.0, 103.0),  // 8
            createCandle(120.0, 105.0, 115.0), // 9: SH1=120 (LH)
            createCandle(118.0, 104.0, 112.0), // 10
            createCandle(117.0, 103.0, 111.0), // 11
            createCandle(105.0, 80.0, 90.0),   // 12: SL1=80 (LL)
            createCandle(107.0, 85.0, 95.0),   // 13
            createCandle(108.0, 86.0, 96.0),   // 14
            createCandle(106.0, 84.0, 95.0)    // 15: close 95. distToSL=(95-80)/95=0.15 > 0.002
        )
        // SH2=130, SH1=120 (LH). SL2=90, SL1=80 (LL). Bearish.
        
        val decision = TradeDecision.SELL
        val gate = MarketStructureGate(decision, bearishCandles)
        assertEquals(TradeDecision.SELL, gate.filter())
    }

    @Test
    fun testRangeStructureBlocks() {
        val rangeCandles = listOf(
            createCandle(110.0, 90.0, 100.0), // 0: SL
            createCandle(115.0, 95.0, 105.0),
            createCandle(120.0, 100.0, 110.0), // 2: SH
            createCandle(115.0, 95.0, 105.0),
            createCandle(110.0, 90.0, 100.0),
            createCandle(112.0, 92.0, 102.0),
            createCandle(114.0, 94.0, 104.0),
            createCandle(116.0, 96.0, 106.0), // 7: SL
            createCandle(114.0, 94.0, 104.0),
            createCandle(112.0, 92.0, 102.0),
            createCandle(115.0, 95.0, 105.0),
            createCandle(118.0, 98.0, 108.0),
            createCandle(122.0, 102.0, 112.0), // 12: SH
            createCandle(120.0, 100.0, 110.0),
            createCandle(118.0, 98.0, 108.0),
            createCandle(117.0, 97.0, 107.0)
        )
        // This won't easily result in clean HH/HL or LH/LL.
        
        val gateBuy = MarketStructureGate(TradeDecision.BUY, rangeCandles)
        assertEquals(TradeDecision.HOLD, gateBuy.filter())
        
        val gateSell = MarketStructureGate(TradeDecision.SELL, rangeCandles)
        assertEquals(TradeDecision.HOLD, gateSell.filter())
    }

    @Test
    fun testBOSBlocks() {
        // Bullish candles from before
        val candles = listOf(
            createCandle(90.0, 70.0, 80.0),
            createCandle(92.0, 75.0, 85.0),
            createCandle(95.0, 80.0, 90.0),
            createCandle(93.0, 78.0, 88.0),
            createCandle(94.0, 82.0, 89.0),
            createCandle(105.0, 90.0, 100.0),
            createCandle(100.0, 85.0, 95.0),
            createCandle(102.0, 88.0, 96.0),
            createCandle(101.0, 84.0, 92.0),
            createCandle(103.0, 86.0, 94.0),
            createCandle(104.0, 87.0, 95.0),
            createCandle(110.0, 95.0, 105.0), // SH1=110
            createCandle(108.0, 94.0, 104.0),
            createCandle(107.0, 93.0, 103.0),
            createCandle(115.0, 100.0, 112.0)  // bosUp = 112 > 110
        )
        
        val gate = MarketStructureGate(TradeDecision.BUY, candles)
        assertEquals(TradeDecision.HOLD, gate.filter()) // Blocks because bosUp is true
    }

    @Test
    fun testNearSwingBlocks() {
        // Bullish structure but close to SH
        val candles = listOf(
            createCandle(90.0, 70.0, 80.0),
            createCandle(92.0, 75.0, 85.0),
            createCandle(95.0, 80.0, 90.0),
            createCandle(93.0, 78.0, 88.0),
