package com.fullpack.panictrader.core

import android.content.Context
import com.fullpack.panictrader.core.memory.LossFeatureSnapshot
import com.fullpack.panictrader.core.memory.LossMemoryFilter
import com.fullpack.panictrader.core.memory.LossMemoryFilterResult
import com.fullpack.panictrader.core.memory.LossMemoryLogger
import com.fullpack.panictrader.core.memory.LossMemoryStore
import com.fullpack.panictrader.core.memory.LossReason
import com.fullpack.panictrader.core.memory.LossScenarioFingerprint
import com.fullpack.panictrader.core.memory.OpenTradeMemoryContext
import com.fullpack.panictrader.core.memory.finalizeOpenTradeMemory
import org.tensorflow.lite.Interpreter
import java.io.File
import java.io.FileInputStream
import java.io.RandomAccessFile
import java.nio.channels.FileChannel
import java.nio.channels.FileLock
import java.nio.channels.OverlappingFileLockException
import java.util.Calendar
import java.util.Locale
import kotlin.math.max
import kotlin.math.pow

enum class Regime { NORMAL, TREND, CHOP, PANIC }
enum class TradeDecision { BUY, SELL, HOLD }

data class EngineResult(
    val regime: Regime,
    val decision: TradeDecision,
    val thresholdUsed: Double?,
    val pSell: Double?,
    val pBuy: Double?,
    val vol: Double?,
    val lastPrice: Double?,
    val log: String
)

class TradingEngine(
    private val context: Context,
    private val configStore: ConfigStore,
    private val secretStore: SecretStore,
    private val bundleMgr: ModelBundleManager
) {
    private val lossMemoryStore = LossMemoryStore(context)
    private val lossMemoryFilter = LossMemoryFilter(lossMemoryStore)

    private data class RunLock(val raf: RandomAccessFile, val lock: FileLock) {
        fun close() {
            runCatching { lock.release() }
            runCatching { raf.close() }
        }
    }

    private fun tryAcquireRunLock(): RunLock? {
        return try {
            val f = File(context.filesDir, "engine_run.lock")
            if (!f.exists()) runCatching { f.createNewFile() }

            val raf = RandomAccessFile(f, "rw")
            val ch = raf.channel
            val lk = ch.tryLock()
            if (lk == null) {
                runCatching { raf.close() }
                null
            } else {
                RunLock(raf, lk)
            }
        } catch (_: OverlappingFileLockException) {
            null
        } catch (_: Exception) {
            null
        }
    }

    suspend fun runOnce(placeOrder: Boolean, forceEntry: Boolean = false): EngineResult {
        val runLock = tryAcquireRunLock()
            ?: return EngineResult(
                Regime.NORMAL,
                TradeDecision.HOLD,
                null, null, null, null, null,
                "SKIPPED: Another run is in progress"
            )

        try {
            val cfg = configStore.getSnapshot()
            val (apiKey, apiSecret) = secretStore.load()
            if (apiKey.isBlank() || apiSecret.isBlank()) {
                return EngineResult(Regime.NORMAL, TradeDecision.HOLD, null, null, null, null, null, "Missing API key/secret")
            }

            if (!bundleMgr.isBundleReady()) {
                return EngineResult(Regime.NORMAL, TradeDecision.HOLD, null, null, null, null, null, "Bundle not ready")
            }

            val bundle = bundleMgr.loadBundle()
            val api = BybitApi(cfg.env, apiKey, apiSecret)
            val symbol = cfg.symbol

            val baseIv = bundle.policy.baseInterval
            val auxIv = bundle.policy.auxInterval
            val baseMins = baseIv.toInt()
            val auxMins = auxIv.toInt()

            val baseCandles = api.getKlines(symbol, baseIv, 400).dropIncompleteLast(baseMins)
            val auxCandles = api.getKlines(symbol, auxIv, 400).dropIncompleteLast(auxMins)

            val baseRows = Indicators.computeFeatureRows(baseCandles, baseMins)
            val auxRows = Indicators.computeFeatureRows(auxCandles, auxMins)

            if (baseRows.isEmpty() || auxRows.isEmpty()) {
                return EngineResult(Regime.NORMAL, TradeDecision.HOLD, null, null, null, null, null, "Not enough candles for indicators")
            }

            val latestBase = baseRows.last()
            val auxMatch = auxRows.lastOrNull { it.endTimeMs <= latestBase.endTimeMs }
                ?: return EngineResult(Regime.NORMAL, TradeDecision.HOLD, null, null, null, null, null, "No aux row matched")

            val feat = buildFeatureVector(bundle.norm.featureCols, symbol, latestBase, auxMatch, baseIv, auxIv)
            val x = FloatArray(feat.size)
            for (i in feat.indices) {
                val mu = bundle.norm.mean[i]
                val sd = bundle.norm.std[i].let { if (it < 1e-8) 1.0 else it }
                x[i] = ((feat[i] - mu) / sd).toFloat()
            }

            val probs = runTflite(bundle.modelFile, x)
            val alpha = bundle.policy.calibration?.alpha ?: 1.0
            val probsCal = probPower(probs, alpha)

            val pSellPro = probsCal[0].toDouble()
            val pBuyPro = probsCal[2].toDouble()

            val vol = latestBase.atrRel
            val (bin, _) = dynThreshold(vol, bundle.policy.dynamicThreshold.binEdges, bundle.policy.dynamicThreshold.thresholds)

            val tradingThreshold = cfg.tradingThreshold

            val rawDecision = when {
                (pBuyPro >= tradingThreshold && pBuyPro >= pSellPro) -> TradeDecision.BUY
                (pSellPro >= tradingThreshold && pSellPro > pBuyPro) -> TradeDecision.SELL
                else -> TradeDecision.HOLD
            }

            val regimeFeatures = mutableMapOf<String, Double>()

            regimeFeatures["base_atr_rel"] = latestBase.atrRel
            regimeFeatures["aux_bb_width"] = auxMatch.bbWidth
            regimeFeatures["aux_ema_slow_rel"] = auxMatch.emaSlowRel
            regimeFeatures["base_rsi"] = latestBase.rsi

            regimeFeatures["atr_rel_${baseIv}m"] = latestBase.atrRel
            regimeFeatures["rsi_${baseIv}m"] = latestBase.rsi
            regimeFeatures["bb_width_${baseIv}m"] = latestBase.bbWidth
            regimeFeatures["ema_slow_rel_${baseIv}m"] = latestBase.emaSlowRel
            regimeFeatures["ema_fast_rel_${baseIv}m"] = latestBase.emaFastRel
            regimeFeatures["macd_rel_${baseIv}m"] = latestBase.macdRel
            regimeFeatures["macd_signal_rel_${baseIv}m"] = latestBase.macdSignalRel
            regimeFeatures["macd_hist_rel_${baseIv}m"] = latestBase.macdHistRel
            regimeFeatures["bb_pos_${baseIv}m"] = latestBase.bbPos
            regimeFeatures["log_ret1_${baseIv}m"] = latestBase.logRet1
            regimeFeatures["hl_pct_${baseIv}m"] = latestBase.hlPct
            regimeFeatures["oc_pct_${baseIv}m"] = latestBase.ocPct
            regimeFeatures["vol_z_${baseIv}m"] = latestBase.volZ

            regimeFeatures["atr_rel_${auxIv}m"] = auxMatch.atrRel
            regimeFeatures["rsi_${auxIv}m"] = auxMatch.rsi
            regimeFeatures["bb_width_${auxIv}m"] = auxMatch.bbWidth
            regimeFeatures["ema_slow_rel_${auxIv}m"] = auxMatch.emaSlowRel
            regimeFeatures["ema_fast_rel_${auxIv}m"] = auxMatch.emaFastRel
            regimeFeatures["macd_rel_${auxIv}m"] = auxMatch.macdRel
            regimeFeatures["macd_signal_rel_${auxIv}m"] = auxMatch.macdSignalRel
            regimeFeatures["macd_hist_rel_${auxIv}m"] = auxMatch.macdHistRel
            regimeFeatures["bb_pos_${auxIv}m"] = auxMatch.bbPos
            regimeFeatures["log_ret1_${auxIv}m"] = auxMatch.logRet1
            regimeFeatures["hl_pct_${auxIv}m"] = auxMatch.hlPct
            regimeFeatures["oc_pct_${auxIv}m"] = auxMatch.ocPct
            regimeFeatures["vol_z_${auxIv}m"] = auxMatch.volZ

            val regimePolicy = bundle.policy.regime ?: RegimePolicy()
            val evaluator = RegimeEvaluator(regimePolicy, regimeFeatures)
            val regime = evaluator.evaluate()

            val strategyDecision = if (forceEntry || (regime == Regime.NORMAL && max(pSellPro, pBuyPro) >= tradingThreshold)) {
                rawDecision
            } else {
                TradeDecision.HOLD
            }

            val msFilteredDecision = if (forceEntry) {
                strategyDecision
            } else {
                val gate = MarketStructureGate(strategyDecision, baseCandles)
                gate.filter()
            }

            val adxMetrics = AdxThirdGate.compute(baseCandles)
            val adxFilteredDecision = if (forceEntry) {
                msFilteredDecision
            } else {
                when (AdxThirdGate.filter(msFilteredDecision, baseCandles, adxThreshold = cfg.adxThreshold)) {
                    AdxGateDecision.ALLOW_LONG -> TradeDecision.BUY
                    AdxGateDecision.ALLOW_SHORT -> TradeDecision.SELL
                    AdxGateDecision.HOLD -> TradeDecision.HOLD
                }
            }

            val marketStructure = runCatching { MarketStructureCalculator.compute(baseCandles) }.getOrNull()

            val preEntrySnapshot = LossScenarioFingerprint.buildSnapshot(
                symbol = symbol,
                regime = regime,
                decision = adxFilteredDecision,
                pBuy = pBuyPro,
                pSell = pSellPro,
                thresholdUsed = tradingThreshold,
                vol = vol,
                adxMetrics = adxMetrics,
                marketStructure = marketStructure,
                latestBase = latestBase,
                auxMatch = auxMatch,
                lastPrice = latestBase.close
            )

            val openPosition = api.getOpenPositionInfo(symbol)

            val lossMemoryResult = if (openPosition != null) {
                LossMemoryFilterResult(
                    finalDecision = adxFilteredDecision,
                    blocked = false,
                    bestScore = null,
                    matchedRecordId = null,
                    message = "Loss memory not applied while position is open"
                )
            } else {
                lossMemoryFilter.filter(adxFilteredDecision, preEntrySnapshot)
            }

            val finalDecision = lossMemoryResult.finalDecision

            var log = String.format(
                Locale.US,
                "MODEL bin=%d thr=%.2f pSell=%.2f pBuy=%.2f regime=%s vol=%.4f decision=%s",
                bin,
                tradingThreshold,
                pSellPro,
                pBuyPro,
                regime.name,
                vol,
                finalDecision.name
            )

            if (strategyDecision != msFilteredDecision) {
                log += " [FILTERED_BY_MS]"
            }
            if (msFilteredDecision != adxFilteredDecision) {
                log += " [FILTERED_BY_ADX]"
            }
            if (adxFilteredDecision != finalDecision) {
                log += " [FILTERED_BY_LOSS_MEMORY]"
            }
            if (forceEntry) log += " [FORCED]"

            log += String.format(
                Locale.US,
                " | ADX=%.2f +DI=%.2f -DI=%.2f",
                adxMetrics.adx,
                adxMetrics.plusDi,
                adxMetrics.minusDi
            )

            if (marketStructure != null) {
                log += String.format(
                    Locale.US,
                    " | MS: bull=%b bear=%b range=%b bosU=%b bosD=%b distH=%.4f distL=%.4f",
                    marketStructure.isBullishStructure,
                    marketStructure.isBearishStructure,
                    marketStructure.isRangeStructure,
                    marketStructure.bosUp,
                    marketStructure.bosDown,
                    marketStructure.distToLastSwingHigh,
                    marketStructure.distToLastSwingLow
                )
            }

            val now = Calendar.getInstance()
            val currentHourTag = (now.get(Calendar.YEAR).toLong() * 1000000L) +
                (now.get(Calendar.DAY_OF_YEAR).toLong() * 100L) +
                now.get(Calendar.HOUR_OF_DAY).toLong()

            if (openPosition != null) {
                val pnl = openPosition.unrealisedPnl?.toDoubleOrNull() ?: 0.0
                val targetTp = cfg.tpAmountUsdt
                val targetSl = cfg.slAmountUsdt
                val isBuyPos = openPosition.side.equals("Buy", ignoreCase = true)

                if (targetTp > 0.0 && pnl >= targetTp) {
                    val sideToClose = if (isBuyPos) Side.SELL else Side.BUY
                    val sizeToClose = openPosition.size.toDoubleOrNull() ?: 0.0
                    if (sizeToClose > 0) {
                        val resp = api.placeMarketOrder(symbol, sideToClose, sizeToClose, null, null, reduceOnly = true)
                        if (resp.contains("\"retCode\":0")) {
                            configStore.setLastTradeHour(currentHourTag)
                            log += String.format(Locale.US, " | TP_EXIT (PNL=%.2f >= %.2f)", pnl, targetTp)
                            log += buildCloseMemoryMarkers(
                                pnl = pnl,
                                exitPrice = latestBase.close,
                                lossReason = LossReason.NEGATIVE_UNKNOWN_EXIT
                            )
                        } else {
                            log += " | TP_EXIT_FAILED"
                        }
                        return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
                    }
                }

                if (targetSl > 0.0 && pnl <= -targetSl) {
                    val sideToClose = if (isBuyPos) Side.SELL else Side.BUY
                    val sizeToClose = openPosition.size.toDoubleOrNull() ?: 0.0
                    if (sizeToClose > 0) {
                        val resp = api.placeMarketOrder(symbol, sideToClose, sizeToClose, null, null, reduceOnly = true)
                        if (resp.contains("\"retCode\":0")) {
                            configStore.setLastTradeHour(currentHourTag)
                            log += String.format(Locale.US, " | SL_AMT_EXIT (PNL=%.2f <= -%.2f)", pnl, targetSl)
                            log += buildCloseMemoryMarkers(
                                pnl = pnl,
                                exitPrice = latestBase.close,
                                lossReason = LossReason.STOP_LOSS_HIT
                            )
                        } else {
                            log += " | SL_AMT_EXIT_FAILED"
                        }
                        return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
                    }
                }

                val holdThreshold = cfg.holdThreshold
                val currentProb = if (isBuyPos) pBuyPro else pSellPro
                if (currentHourTag > cfg.lastTradeHour && currentProb < holdThreshold) {
                    val sideToClose = if (isBuyPos) Side.SELL else Side.BUY
                    val sizeToClose = openPosition.size.toDoubleOrNull() ?: 0.0
                    if (sizeToClose > 0) {
                        val resp = api.placeMarketOrder(symbol, sideToClose, sizeToClose, null, null, reduceOnly = true)
                        if (resp.contains("\"retCode\":0")) {
                            configStore.setLastTradeHour(currentHourTag)
                            log += String.format(Locale.US, " | EXIT_LOW_PROB (%.2f < %.2f)", currentProb, holdThreshold)
                            log += buildCloseMemoryMarkers(
                                pnl = pnl,
                                exitPrice = latestBase.close,
                                lossReason = LossReason.NEGATIVE_LOW_PROB_EXIT
                            )
                        } else {
                            log += " | EXIT_LOW_PROB_FAILED"
                        }
                        return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
                    }
                }

                if (regime != Regime.NORMAL) {
                    val sideToClose = if (isBuyPos) Side.SELL else Side.BUY
                    val sizeToClose = openPosition.size.toDoubleOrNull() ?: 0.0
                    if (sizeToClose > 0) {
                        val resp = api.placeMarketOrder(symbol, sideToClose, sizeToClose, null, null, reduceOnly = true)
                        if (resp.contains("\"retCode\":0")) {
                            configStore.setLastTradeHour(currentHourTag)
                            log += " | EXIT_ON_REGIME_CHANGE ($regime)"
                            log += buildCloseMemoryMarkers(
                                pnl = pnl,
                                exitPrice = latestBase.close,
                                lossReason = LossReason.NEGATIVE_REGIME_EXIT
                            )
                        } else {
                            log += " | EXIT_FAILED"
                        }
                        return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
                    }
                }

                val isFlip = (isBuyPos && rawDecision == TradeDecision.SELL) || (!isBuyPos && rawDecision == TradeDecision.BUY)
                if (isFlip) {
                    val sideToClose = if (isBuyPos) Side.SELL else Side.BUY
                    val sizeToClose = openPosition.size.toDoubleOrNull() ?: 0.0
                    if (sizeToClose > 0) {
                        val resp = api.placeMarketOrder(symbol, sideToClose, sizeToClose, null, null, reduceOnly = true)
                        if (resp.contains("\"retCode\":0")) {
                            configStore.setLastTradeHour(currentHourTag)
                            log += " | EXIT_ON_SIGNAL_FLIP"
                            log += buildCloseMemoryMarkers(
                                pnl = pnl,
                                exitPrice = latestBase.close,
                                lossReason = LossReason.NEGATIVE_SIGNAL_FLIP_CLOSE
                            )
                        } else {
                            log += " | FLIP_EXIT_FAILED"
                        }
                        return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
                    }
                }

                log += String.format(Locale.US, " | HOLDING (PNL=%.2f PROB=%.2f)", pnl, currentProb)
                return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
            } else {
                val reserve = cfg.reserveUtaUsdt
                if (reserve > 0.0) {
                    runCatching {
                        val bal = api.getWalletBalanceUsdt()
                        if (bal > reserve) {
                            val excess = bal - reserve
                            val resp = api.transferUtaToFunding(excess)
                            if (resp.contains("\"retCode\":0")) {
                                log += String.format(Locale.US, " | XFER_OK: %.2f", excess)
                            } else {
                                log += " | XFER_FAILED"
                            }
                        }
                    }
                }
            }

            if (placeOrder && finalDecision != TradeDecision.HOLD) {
                if (cfg.lastTradeHour == currentHourTag && !forceEntry) {
                    log += " | SKIPPED: Hourly Limit"
                    return EngineResult(regime, TradeDecision.HOLD, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
                }

                val lev = cfg.leverage
                val stakePct = cfg.stakePct
                val fixedQty = cfg.fixedQty
                runCatching { api.setLeverage(symbol, lev) }

                val qty = runCatching {
                    val bal = api.getWalletBalanceUsdt()
                    val stakeUsdt = bal * (stakePct / 100.0)
                    val notional = stakeUsdt * lev
                    (notional / latestBase.close).coerceAtLeast(0.0)
                }.getOrElse { fixedQty }

                val tpPrice = priceFromPct(latestBase.close, cfg.tpPct, finalDecision, isTp = true)
                val slPrice = priceFromPct(latestBase.close, cfg.slPct, finalDecision, isTp = false)

                val side = if (finalDecision == TradeDecision.BUY) Side.BUY else Side.SELL
                val resp = api.placeMarketOrder(symbol, side, qty, tpPrice, slPrice)

                if (resp.contains("\"retCode\":0")) {
                    configStore.setLastTradeHour(currentHourTag)
                    log += " | ENTRY_OK"
                    log += saveOpenTradeContextMarker(
                        symbol = symbol,
                        finalDecision = finalDecision,
                        currentHourTag = currentHourTag,
                        entryPriceApprox = latestBase.close,
                        regime = regime,
                        preEntrySnapshot = preEntrySnapshot
                    )
                } else {
                    log += " | ENTRY_FAILED"
                }
            }

            return EngineResult(regime, finalDecision, tradingThreshold, pSellPro, pBuyPro, vol, latestBase.close, log)
        } finally {
            runLock.close()
        }
    }

    private suspend fun buildCloseMemoryMarkers(
        pnl: Double,
        exitPrice: Double?,
        lossReason: LossReason
    ): String {
        val outcome = finalizeOpenTradeMemory(
            repository = lossMemoryStore,
            pnl = pnl,
            exitPrice = exitPrice,
            lossReasonWhenNegative = lossReason
        )
        return buildString {
            if (outcome.savedLoss) {
                append(" [LOSS_MEMORY_SAVED]")
            } else if (outcome.skippedNoContext) {
                append(" [LOSS_MEMORY_SKIPPED_NO_CONTEXT]")
            }
            if (outcome.clearedContext) {
                append(" [OPEN_TRADE_CONTEXT_CLEARED]")
            }
        }
    }

    private suspend fun saveOpenTradeContextMarker(
        symbol: String,
        finalDecision: TradeDecision,
        currentHourTag: Long,
        entryPriceApprox: Double?,
        regime: Regime,
        preEntrySnapshot: LossFeatureSnapshot
    ): String {
        val ctx = OpenTradeMemoryContext(
            symbol = symbol,
            entrySide = finalDecision.name,
            entryTimeMs = System.currentTimeMillis(),
            entryHourTag = currentHourTag,
            entryPriceApprox = entryPriceApprox,
            regimeAtEntry = regime.name,
            decisionAtEntry = finalDecision.name,
            preEntrySnapshot = preEntrySnapshot
        )

        return runCatching {
            lossMemoryStore.saveOpenTradeContext(ctx)
            " [OPEN_TRADE_CONTEXT_SAVED]"
        }.getOrElse {
            LossMemoryLogger.e("failed to save open trade context from TradingEngine", it)
            ""
        }
    }

    private fun runTflite(modelFile: File, input: FloatArray): FloatArray {
        FileInputStream(modelFile).use { fis ->
            val buffer = fis.channel.map(FileChannel.MapMode.READ_ONLY, 0, modelFile.length())
            val interpreter = Interpreter(buffer)
            try {
                val output = Array(1) { FloatArray(3) }
                interpreter.run(arrayOf(input), output)
                return output[0]
            } finally {
                interpreter.close()
            }
        }
    }

    private fun probPower(p: FloatArray, alpha: Double): FloatArray {
        val x0 = (p[0].toDouble().coerceIn(1e-12, 1.0)).pow(alpha)
        val x1 = (p[1].toDouble().coerceIn(1e-12, 1.0)).pow(alpha)
        val x2 = (p[2].toDouble().coerceIn(1e-12, 1.0)).pow(alpha)
        val s = x0 + x1 + x2
        return floatArrayOf((x0 / s).toFloat(), (x1 / s).toFloat(), (x2 / s).toFloat())
    }

    private fun dynThreshold(vol: Double, edges: List<Double>, thresholds: List<Double>): Pair<Int, Double> {
        var bin = 0
        for (e in edges) {
            if (vol >= e) bin++
        }
        if (bin < 0) bin = 0
        if (bin > thresholds.lastIndex) bin = thresholds.lastIndex
        return bin to thresholds[bin]
    }

    private fun priceFromPct(price: Double, pct: Double, decision: TradeDecision, isTp: Boolean): Double? {
        if (pct <= 0.0) return null
        val p = pct / 100.0
        return when (decision) {
            TradeDecision.BUY -> if (isTp) price * (1 + p) else price * (1 - p)
            TradeDecision.SELL -> if (isTp) price * (1 - p) else price * (1 + p)
            else -> null
        }
    }

    private fun buildFeatureVector(
        featureCols: List<String>,
        symbol: String,
        base: FeatureRow,
        aux: FeatureRow,
        baseIv: String,
        auxIv: String
    ): DoubleArray {
        val out = DoubleArray(featureCols.size)
        for (i in featureCols.indices) {
            val c = featureCols[i]
            out[i] = when (c) {
                "ema_fast_rel_${baseIv}m" -> base.emaFastRel
                "ema_slow_rel_${baseIv}m" -> base.emaSlowRel
                "rsi_${baseIv}m" -> base.rsi
                "macd_rel_${baseIv}m" -> base.macdRel
                "macd_signal_rel_${baseIv}m" -> base.macdSignalRel
                "macd_hist_rel_${baseIv}m" -> base.macdHistRel
                "bb_pos_${baseIv}m" -> base.bbPos
                "bb_width_${baseIv}m" -> base.bbWidth
                "atr_rel_${baseIv}m" -> base.atrRel
                "log_ret1_${baseIv}m" -> base.logRet1
                "hl_pct_${baseIv}m" -> base.hlPct
                "oc_pct_${baseIv}m" -> base.ocPct
                "vol_z_${baseIv}m" -> base.volZ
                "ema_fast_rel_${auxIv}m" -> aux.emaFastRel
                "ema_slow_rel_${auxIv}m" -> aux.emaSlowRel
                "rsi_${auxIv}m" -> aux.rsi
                "macd_rel_${auxIv}m" -> aux.macdRel
                "macd_signal_rel_${auxIv}m" -> aux.macdSignalRel
                "macd_hist_rel_${auxIv}m" -> aux.macdHistRel
                "bb_pos_${auxIv}m" -> aux.bbPos
                "bb_width_${auxIv}m" -> aux.bbWidth
                "atr_rel_${auxIv}m" -> aux.atrRel
                "log_ret1_${auxIv}m" -> aux.logRet1
                "hl_pct_${auxIv}m" -> aux.hlPct
                "oc_pct_${auxIv}m" -> aux.ocPct
                "vol_z_${auxIv}m" -> aux.volZ
                else -> {
                    if (c.startsWith("sym_")) {
                        if (symbol.contains(c.removePrefix("sym_"), ignoreCase = true)) 1.0 else 0.0
                    } else {
                        Double.NaN
                    }
                }
            }
        }

        require(out.all { it.isFinite() }) { "Feature vector has NaN/Inf. Check feature_cols mapping." }
        return out
    }
}

private fun List<Candle>.dropIncompleteLast(intervalMinutes: Int): List<Candle> {
    if (isEmpty()) return this
    val last = last()
    val now = System.currentTimeMillis()
    val end = last.startTimeMs + intervalMinutes * 60_000L
    return if (now < end) dropLast(1) else this
}
