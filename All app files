@Composable
fun OceanBackground(isNight: Boolean) {
    val infiniteTransition = rememberInfiniteTransition()
    val waveOffset by infiniteTransition.animateFloat(
        initialValue = 0f,
        targetValue = 100f,
        animationSpec = infiniteRepeatable(
            animation = tween(4000, easing = LinearOutSlowInEasing),
            repeatMode = RepeatMode.Reverse
        )
    )

    val seaColorStart = if (isNight) DeepSeaBlue.copy(0.8f) else OceanBlue.copy(0.4f)
    val seaColorEnd = if (isNight) Color(0xFF01579B).copy(0.9f) else DeepSeaBlue.copy(0.6f)

    Canvas(modifier = Modifier.fillMaxSize()) {
        val height = size.height
        val width = size.width
        
        // Sea
        drawRect(
            brush = Brush.verticalGradient(listOf(seaColorStart, seaColorEnd)),
            topLeft = Offset(0f, height * 0.75f),
            size = Size(width, height * 0.25f)
        )
        
        // Waves
        val wavePath = Path().apply {
            val startY = height * 0.75f
            moveTo(0f, startY)
            
            val segmentWidth = width / 4f
            for (i in 0..3) {
                val cp1X = (i * segmentWidth) + (segmentWidth * 0.25f)
                val cp1Y = startY - 15f + (waveOffset / 4f)
                val cp2X = (i * segmentWidth) + (segmentWidth * 0.75f)
                val cp2Y = startY + 15f - (waveOffset / 4f)
                val endX = (i + 1) * segmentWidth
                
                cubicTo(cp1X, cp1Y, cp2X, cp2Y, endX, startY)
            }
            
            lineTo(width, height)
            lineTo(0f, height)
            close()
        }
        drawPath(wavePath, Color.White.copy(if (isNight) 0.1f else 0.3f))
    }
}

@Composable
fun CoconutTree(modifier: Modifier) {
    Canvas(modifier = modifier.size(120.dp)) {
        val w = size.width
        val h = size.height
        
        // Trunk
        val trunkPath = Path().apply {
            moveTo(w * 0.4f, h)
            quadraticBezierTo(w * 0.35f, h * 0.5f, w * 0.5f, h * 0.2f)
            lineTo(w * 0.6f, h * 0.22f)
            quadraticBezierTo(w * 0.45f, h * 0.5f, w * 0.5f, h)
            close()
        }
        drawPath(trunkPath, PalmTrunk)
        
        // Leaves
        rotate(-30f, Offset(w * 0.5f, h * 0.2f)) {
            for (i in 0..4) {
                rotate(i * 50f, Offset(w * 0.5f, h * 0.2f)) {
                    drawOval(
                        PalmLeaf,
                        topLeft = Offset(w * 0.2f, h * 0.1f),
                        size = Size(w * 0.4f, h * 0.15f)
                    )
                }
            }
        }
        
        // Coconuts
        drawCircle(PalmTrunk, 6.dp.toPx(), Offset(w * 0.48f, h * 0.25f))
        drawCircle(PalmTrunk, 5.dp.toPx(), Offset(w * 0.55f, h * 0.23f))
    }
}

