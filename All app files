data class UiState(
    val env: BybitEnv = BybitEnv.DEMO,
    val baseUrl: String = BybitEnv.DEMO.baseUrl,

    val apiKey: String = "",
    val apiSecret: String = "",
    val keysSaved: Boolean = false,

    val bundleInfo: String = "not loaded",
    val bundleReady: Boolean = false,

    val symbol: String = "BTCUSDT",
    val leverage: String = "3",
    val stakePct: String = "10",
    val tpPct: String = "1.0",
    val slPct: String = "0.8",
    val fixedQty: String = "0.001",
    val threshold: String = "0.60",
    val tpAmountUsdt: String = "0.0",
    val reserveUtaUsdt: String = "0.0",
    val holdThreshold: String = "0.57",
    val adxThreshold: String = "25.0",
    val slAmountUsdt: String = "0.0",

    val autoEnabled: Boolean = false,

    val regime: String = "UNKNOWN",
    val decision: TradeDecision = TradeDecision.HOLD,
    val thresholdUsed: String = "-",
    val pSell: String = "-",
    val pBuy: String = "-",
    val volValue: String = "-",
    val lastPrice: String = "-",
    val lastLog: String = "",
    val balance: String = "-"
)

class MainViewModel(
    private val appContext: Context,
    private val config: ConfigStore,
    private val secrets: SecretStore,
    private val bundleMgr: ModelBundleManager,
) : ViewModel() {

    private val _uiState = MutableStateFlow(UiState())
    val uiState: StateFlow<UiState> = _uiState

    private val engine = TradingEngine(appContext, config, secrets, bundleMgr)
    private var autoTraderJob: Job? = null

    init {
        viewModelScope.launch {
            bundleMgr.ensureDefaultBundle()
            reloadBundle()
            loadSecrets()
            loadConfig()
        }
    }

    override fun onCleared() {
        autoTraderJob?.cancel()
        super.onCleared()
    }

    fun setEnv(env: BybitEnv) = viewModelScope.launch {
        _uiState.value = _uiState.value.copy(env = env, baseUrl = env.baseUrl)
        config.setEnv(env)
    }

    fun setApiKeyTemp(v: String) { _uiState.value = _uiState.value.copy(apiKey = v) }
    fun setApiSecretTemp(v: String) { _uiState.value = _uiState.value.copy(apiSecret = v) }

    fun saveApiKeys() = viewModelScope.launch {
        secrets.save(_uiState.value.apiKey.trim(), _uiState.value.apiSecret.trim())
        _uiState.value = _uiState.value.copy(keysSaved = true)
    }

    private fun loadSecrets() {
        val (k, s) = secrets.load()
        _uiState.value = _uiState.value.copy(
            apiKey = k,
            apiSecret = s,
            keysSaved = k.isNotBlank() && s.isNotBlank()
        )
    }

    private fun loadConfig() = viewModelScope.launch {
        val c = config.getSnapshot()
        _uiState.value = _uiState.value.copy(
            env = c.env,
            baseUrl = c.env.baseUrl,
            symbol = c.symbol,
            leverage = c.leverage.toString(),
            stakePct = c.stakePct.toString(),
            tpPct = c.tpPct.toString(),
            slPct = c.slPct.toString(),
            fixedQty = c.fixedQty.toString(),
            threshold = c.tradingThreshold.toString(),
            tpAmountUsdt = c.tpAmountUsdt.toString(),
            reserveUtaUsdt = c.reserveUtaUsdt.toString(),
            holdThreshold = c.holdThreshold.toString(),
            adxThreshold = c.adxThreshold.toString(),
            slAmountUsdt = c.slAmountUsdt.toString(),
            autoEnabled = c.autoEnabled
        )

        scheduleWorker(c.autoEnabled)
        if (c.autoEnabled) startAutoTrader()
    }

    fun setSymbol(v: String) = viewModelScope.launch {
        val s = v.trim()
        config.setSymbol(s)
        _uiState.value = _uiState.value.copy(symbol = s)
    }

    fun setLeverage(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(leverage = v) }
    fun setStakePct(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(stakePct = v) }
    fun setTpPct(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(tpPct = v) }
    fun setSlPct(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(slPct = v) }
    fun setFixedQty(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(fixedQty = v) }
    fun setThreshold(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(threshold = v) }
    fun setTpAmountUsdt(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(tpAmountUsdt = v) }
    fun setReserveUtaUsdt(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(reserveUtaUsdt = v) }
    fun setHoldThreshold(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(holdThreshold = v) }
    fun setAdxThreshold(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(adxThreshold = v) }
    fun setSlAmountUsdt(v: String) = viewModelScope.launch { _uiState.value = _uiState.value.copy(slAmountUsdt = v) }

    fun saveTradingSettings() = viewModelScope.launch {
        persistTradingSettings(showSuccessLog = true)
    }

    private suspend fun persistTradingSettings(showSuccessLog: Boolean): Boolean {
        fun parse(label: String, raw: String): Double? {
            val v = raw.trim().toDoubleOrNull()
            if (v == null) _uiState.value = _uiState.value.copy(lastLog = "Invalid $label: '$raw'")
            return v
        }

        val lev = parse("Leverage", _uiState.value.leverage) ?: return false
        val stake = parse("Stake %", _uiState.value.stakePct) ?: return false
        val tp = parse("TP %", _uiState.value.tpPct) ?: return false
        val sl = parse("SL %", _uiState.value.slPct) ?: return false
        val qty = parse("Fixed Qty", _uiState.value.fixedQty) ?: return false
        val thr = parse("Threshold", _uiState.value.threshold) ?: return false
        val tpAmt = parse("TP USDT", _uiState.value.tpAmountUsdt) ?: return false
        val reserve = parse("UTA Reserve", _uiState.value.reserveUtaUsdt) ?: return false
        val holdThr = parse("Hold Thr", _uiState.value.holdThreshold) ?: return false
        val adxThr = parse("ADX Thr", _uiState.value.adxThreshold) ?: return false
        val slAmt = parse("SL USDT", _uiState.value.slAmountUsdt) ?: return false

        if (lev <= 0.0) { _uiState.value = _uiState.value.copy(lastLog = "Leverage must be > 0"); return false }
        if (stake <= 0.0 || stake > 100.0) { _uiState.value = _uiState.value.copy(lastLog = "Stake % must be (0, 100]"); return false }
        if (tp < 0.0) { _uiState.value = _uiState.value.copy(lastLog = "TP % must be >= 0"); return false }
        if (sl < 0.0) { _uiState.value = _uiState.value.copy(lastLog = "SL % must be >= 0"); return false }
        if (qty <= 0.0) { _uiState.value = _uiState.value.copy(lastLog = "Fixed Qty must be > 0"); return false }
        if (thr < 0.0 || thr > 1.0) { _uiState.value = _uiState.value.copy(lastLog = "Threshold must be [0, 1]"); return false }
        if (tpAmt < 0.0) { _uiState.value = _uiState.value.copy(lastLog = "TP USDT must be >= 0"); return false }
        if (reserve < 0.0) { _uiState.value = _uiState.value.copy(lastLog = "UTA Reserve must be >= 0"); return false }
        if (holdThr < 0.0 || holdThr > 1.0) { _uiState.value = _uiState.value.copy(lastLog = "Hold Thr must be [0, 1]"); return false }
        if (adxThr < 0.0) { _uiState.value = _uiState.value.copy(lastLog = "ADX Thr must be >= 0"); return false }
        if (slAmt < 0.0) { _uiState.value = _uiState.value.copy(lastLog = "SL USDT must be >= 0"); return false }

        config.saveTradingNumbers(
            leverage = lev,
            stakePct = stake,
            tpPct = tp,
            slPct = sl,
            fixedQty = qty,
            tradingThreshold = thr,
            tpAmountUsdt = tpAmt,
            reserveUtaUsdt = reserve,
            holdThreshold = holdThr,
            adxThreshold = adxThr,
            slAmountUsdt = slAmt
        )

        if (showSuccessLog) _uiState.value = _uiState.value.copy(lastLog = "Saved trading settings.")
        return true
    }

    fun setAutoEnabled(enabled: Boolean) = viewModelScope.launch {
        if (enabled) {
            val ok = persistTradingSettings(showSuccessLog = false)
            if (!ok) {
                config.setAutoEnabled(false)
                scheduleWorker(false)
                stopAutoTrader()
                _uiState.value = _uiState.value.copy(autoEnabled = false)
                return@launch
            }
        }

        config.setAutoEnabled(enabled)
        _uiState.value = _uiState.value.copy(autoEnabled = enabled)

        scheduleWorker(enabled)

        if (enabled) startAutoTrader() else stopAutoTrader()
    }

    private fun scheduleWorker(enabled: Boolean) {
        val wm = WorkManager.getInstance(appContext)

        if (!enabled) {
            wm.cancelUniqueWork(TradingWorker.UNIQUE_NAME)
            return
        }

        val constraints = Constraints.Builder()
            .setRequiredNetworkType(NetworkType.CONNECTED)
            .build()

        val req = PeriodicWorkRequestBuilder<TradingWorker>(15, TimeUnit.MINUTES)
            .addTag(TradingWorker.TAG)
            .setConstraints(constraints)
            .build()

        wm.enqueueUniquePeriodicWork(
            TradingWorker.UNIQUE_NAME,
            ExistingPeriodicWorkPolicy.UPDATE,
            req
        )
    }

    private fun startAutoTrader() {
        autoTraderJob?.cancel()
        autoTraderJob = viewModelScope.launch(Dispatchers.Default) {
            while (isActive) {
                _uiState.value = _uiState.value.copy(lastLog = "AUTO: Checking market...")
                try {
                    val r = engine.runOnce(placeOrder = true)
                    _uiState.value = _uiState.value.copy(
                        regime = r.regime.toString(),
                        decision = r.decision,
                        thresholdUsed = r.thresholdUsed?.toString() ?: "-",
                        pSell = r.pSell?.toString() ?: "-",
                        pBuy = r.pBuy?.toString() ?: "-",
                        volValue = r.vol?.toString() ?: "-",
                        lastPrice = r.lastPrice?.toString() ?: "-",
                        lastLog = "AUTO: " + r.log
                    )
                } catch (e: Exception) {
                    _uiState.value = _uiState.value.copy(lastLog = "AUTO: Error - ${e.message}")
                }
                delay(60_000L)
            }
        }
    }

    private fun stopAutoTrader() {
        autoTraderJob?.cancel()
        _uiState.value = _uiState.value.copy(lastLog = "AUTO: Stopped.")
    }

    fun reloadBundle() = viewModelScope.launch {
        val info = bundleMgr.describeCurrent()
        val ok = bundleMgr.isBundleReady()
        _uiState.value = _uiState.value.copy(bundleInfo = info, bundleReady = ok)
    }

    fun useDefaultBundle() = viewModelScope.launch {
        bundleMgr.useDefaultBundle()
        reloadBundle()
    }

    fun importPolicy(uri: Uri) = viewModelScope.launch { bundleMgr.importPolicy(uri); reloadBundle() }
    fun importNorm(uri: Uri) = viewModelScope.launch { bundleMgr.importNorm(uri); reloadBundle() }
    fun importModel(uri: Uri) = viewModelScope.launch { bundleMgr.importModel(uri); reloadBundle() }

    fun runDecisionOnce() = viewModelScope.launch(Dispatchers.Default) {
        val ok = persistTradingSettings(showSuccessLog = false)
        if (!ok) return@launch

        _uiState.value = _uiState.value.copy(lastLog = "Running decision...")
        try {
            val r = engine.runOnce(placeOrder = false)
            _uiState.value = _uiState.value.copy(
                regime = r.regime.toString(),
                decision = r.decision,
                thresholdUsed = r.thresholdUsed?.toString() ?: "-",
                pSell = r.pSell?.toString() ?: "-",
                pBuy = r.pBuy?.toString() ?: "-",
                volValue = r.vol?.toString() ?: "-",
                lastPrice = r.lastPrice?.toString() ?: "-",
                lastLog = r.log
            )
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(lastLog = "Error: ${e.message}")
        }
    }

    fun placeOrderNow() = viewModelScope.launch(Dispatchers.Default) {
        val ok = persistTradingSettings(showSuccessLog = false)
        if (!ok) return@launch

        _uiState.value = _uiState.value.copy(lastLog = "Placing order (PANIC ONLY)...")
        try {
            val r = engine.runOnce(placeOrder = true, forceEntry = true)
            _uiState.value = _uiState.value.copy(
                regime = r.regime.toString(),
                decision = r.decision,
                thresholdUsed = r.thresholdUsed?.toString() ?: "-",
                pSell = r.pSell?.toString() ?: "-",
                pBuy = r.pBuy?.toString() ?: "-",
                volValue = r.vol?.toString() ?: "-",
                lastPrice = r.lastPrice?.toString() ?: "-",
                lastLog = r.log
            )
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(lastLog = "Error: ${e.message}")
        }
    }

    fun fetchBalance() = viewModelScope.launch {
        try {
            val (apiKey, apiSecret) = secrets.load()
            if (apiKey.isBlank() || apiSecret.isBlank()) {
                _uiState.value = _uiState.value.copy(balance = "Missing API keys")
                return@launch
            }
            val api = BybitApi(_uiState.value.env, apiKey, apiSecret)
            val balance = api.getWalletBalanceUsdt()
            _uiState.value = _uiState.value.copy(balance = "$balance USDT")
        } catch (e: Exception) {
            _uiState.value = _uiState.value.copy(balance = "Error: ${e.message}")
        }
    }

    companion object {
        fun factory(appContext: Context): ViewModelProvider.Factory =
            object : ViewModelProvider.Factory {
                @Suppress("UNCHECKED_CAST")
                override fun <T : ViewModel> create(modelClass: Class<T>): T {
                    val cfg = ConfigStore(appContext)
                    val sec = SecretStore(appContext)
                    val bm = ModelBundleManager(appContext)
                    return MainViewModel(appContext, cfg, sec, bm) as T
                }
            }
    }
}








