package com.fullpack.panictrader.core.memory

import android.content.Context
import androidx.datastore.preferences.core.edit
import androidx.datastore.preferences.core.stringPreferencesKey
import androidx.datastore.preferences.preferencesDataStore
import kotlinx.coroutines.flow.first
import kotlinx.serialization.builtins.ListSerializer
import kotlinx.serialization.encodeToString
import kotlinx.serialization.json.Json
import java.util.UUID

private val Context.lossMemoryDataStore by preferencesDataStore(name = "panic_trader_loss_memory")

interface LossMemoryRepository {
    suspend fun getLossRecords(): List<LossScenarioRecord>
    suspend fun saveLossRecord(record: LossScenarioRecord)
    suspend fun saveLossRecordIfNew(record: LossScenarioRecord): Boolean
    suspend fun pruneExpired()
    suspend fun trimToMaxSize()
    suspend fun getOpenTradeContext(): OpenTradeMemoryContext?
    suspend fun saveOpenTradeContext(ctx: OpenTradeMemoryContext)
    suspend fun clearOpenTradeContext()
}

class LossMemoryStore(private val context: Context) : LossMemoryRepository {

    private val recordsKey = stringPreferencesKey("loss_records_json")
    private val openTradeKey = stringPreferencesKey("open_trade_context_json")

    override suspend fun getLossRecords(): List<LossScenarioRecord> {
        return runCatching {
            val prefs = context.lossMemoryDataStore.data.first()
            sanitizeRecords(decodeRecordsOrEmpty(prefs[recordsKey]))
        }.getOrElse {
            LossMemoryLogger.w("failed to load loss records", it)
            emptyList()
        }
    }

    override suspend fun saveLossRecord(record: LossScenarioRecord) {
        saveLossRecordIfNew(record)
    }

    override suspend fun saveLossRecordIfNew(record: LossScenarioRecord): Boolean {
        return runCatching {
            if (record.pnl >= 0.0) {
                LossMemoryLogger.i("ignoring non-negative scenario pnl=${record.pnl}")
                return@runCatching false
            }

            val normalized = record.copy(
                id = record.id.ifBlank { UUID.randomUUID().toString() },
                createdAtMs = if (record.createdAtMs > 0L) record.createdAtMs else System.currentTimeMillis(),
                fingerprintVersion = if (record.fingerprintVersion > 0) {
                    record.fingerprintVersion
                } else {
                    LossMemoryConfig.FINGERPRINT_VERSION
                }
            )

            val existing = getLossRecords()
            val duplicate = existing
                .take(25)
                .any { saved ->
                    saved.fingerprintVersion == normalized.fingerprintVersion &&
                        saved.symbol.equals(normalized.symbol, ignoreCase = true) &&
                        saved.intendedDecision.equals(normalized.intendedDecision, ignoreCase = true) &&
                        LossScenarioMatcher.compareSnapshots(
                            currentSnapshot = normalized.featureSnapshot,
                            pastSnapshot = saved.featureSnapshot,
                            matchedRecordId = saved.id
                        ).score >= LossMemoryConfig.DUPLICATE_SIMILARITY_THRESHOLD
                }

            if (duplicate) {
                LossMemoryLogger.i("duplicate negative setup detected, skipping insert")
                return@runCatching false
            }

            val updated = sanitizeRecords(listOf(normalized) + existing)
            writeRecords(updated)
            LossMemoryLogger.i("saved negative scenario pnl=${normalized.pnl} reason=${normalized.lossReason}")
            true
        }.getOrElse {
            LossMemoryLogger.e("failed to save loss record", it)
            false
        }
    }

    override suspend fun pruneExpired() {
        runCatching {
            val current = getLossRecords()
            writeRecords(sanitizeRecords(current))
        }.onFailure {
            LossMemoryLogger.w("failed to prune loss records", it)
        }
    }

    override suspend fun trimToMaxSize() {
        runCatching {
            val current = getLossRecords()
            writeRecords(sanitizeRecords(current))
        }.onFailure {
            LossMemoryLogger.w("failed to trim loss records", it)
        }
    }

    override suspend fun getOpenTradeContext(): OpenTradeMemoryContext? {
        return runCatching {
            val prefs = context.lossMemoryDataStore.data.first()
            decodeOpenTradeContextOrNull(prefs[openTradeKey])
        }.getOrElse {
            LossMemoryLogger.w("failed to load open trade context", it)
            null
        }
    }

    override suspend fun saveOpenTradeContext(ctx: OpenTradeMemoryContext) {
        context.lossMemoryDataStore.edit { prefs ->
            prefs[openTradeKey] = codec.encodeToString(OpenTradeMemoryContext.serializer(), ctx)
        }
        LossMemoryLogger.i("open trade context saved")
    }

    override suspend fun clearOpenTradeContext() {
        context.lossMemoryDataStore.edit { prefs ->
            prefs.remove(openTradeKey)
        }
        LossMemoryLogger.i("open trade context cleared")
    }

    private suspend fun writeRecords(records: List<LossScenarioRecord>) {
        context.lossMemoryDataStore.edit { prefs ->
            prefs[recordsKey] = codec.encodeToString(ListSerializer(LossScenarioRecord.serializer()), records)
        }
    }

    private fun sanitizeRecords(records: List<LossScenarioRecord>): List<LossScenarioRecord> {
        val cutoff = System.currentTimeMillis() - LossMemoryConfig.maxAgeMs()
        return records
            .asSequence()
            .filter { it.pnl < 0.0 }
            .filter { it.createdAtMs >= cutoff }
            .sortedByDescending { it.createdAtMs }
            .take(LossMemoryConfig.MAX_RECORDS)
            .toList()
    }

    companion object {
        private val codec = Json {
            ignoreUnknownKeys = true
            encodeDefaults = true
        }

        fun decodeRecordsOrEmpty(raw: String?): List<LossScenarioRecord> {
            if (raw.isNullOrBlank()) return emptyList()
            return runCatching {
                codec.decodeFromString(ListSerializer(LossScenarioRecord.serializer()), raw)
            }.getOrElse {
                emptyList()
            }
        }

        fun decodeOpenTradeContextOrNull(raw: String?): OpenTradeMemoryContext? {
            if (raw.isNullOrBlank()) return null
            return runCatching {
                codec.decodeFromString(OpenTradeMemoryContext.serializer(), raw)
            }.getOrNull()
        }
    }
}

suspend fun finalizeOpenTradeMemory(
    repository: LossMemoryRepository,
    pnl: Double,
    exitPrice: Double?,
    lossReasonWhenNegative: LossReason,
    notes: String? = null
): LossMemoryCloseResult {
    val context = runCatching { repository.getOpenTradeContext() }.getOrElse {
        LossMemoryLogger.e("failed to read open trade context before close handling", it)
        null
    }

    if (context == null) {
        if (pnl < 0.0) {
            LossMemoryLogger.i("save skipped, missing open trade context")
            return LossMemoryCloseResult(
                savedLoss = false,
                skippedNoContext = true,
                clearedContext = false,
                recordId = null
            )
        }
        return LossMemoryCloseResult(
            savedLoss = false,
            skippedNoContext = false,
            clearedContext = false,
            recordId = null
        )
    }

    var savedLoss = false
    var savedRecordId: String? = null

    if (pnl < 0.0) {
        val record = LossScenarioRecord(
            id = UUID.randomUUID().toString(),
            createdAtMs = System.currentTimeMillis(),
            symbol = context.symbol,
            regime = context.regimeAtEntry,
            intendedDecision = context.decisionAtEntry,
            actualEntrySide = context.entrySide,
            entryPrice = context.entryPriceApprox,
            exitPrice = exitPrice,
            pnl = pnl,
            lossReason = lossReasonWhenNegative,
            featureSnapshot = context.preEntrySnapshot,
            fingerprintVersion = LossMemoryConfig.FINGERPRINT_VERSION,
            notes = notes
        )
        savedLoss = runCatching { repository.saveLossRecordIfNew(record) }
            .getOrElse {
                LossMemoryLogger.e("failed to persist negative scenario", it)
                false
            }
        if (savedLoss) {
            savedRecordId = record.id
        }
    }

    val clearedContext = runCatching {
        repository.clearOpenTradeContext()
        true
    }.getOrElse {
        LossMemoryLogger.e("failed to clear open trade context after close", it)
        false
    }

    return LossMemoryCloseResult(
        savedLoss = savedLoss,
        skippedNoContext = false,
        clearedContext = clearedContext,
        recordId = savedRecordId
    )
}
