package com.fullpack.panictrader.core.memory

import com.fullpack.panictrader.core.TradeDecision
import java.util.Locale

class LossMemoryFilter(
    private val repository: LossMemoryRepository
) {

    suspend fun filter(
        proposedDecision: TradeDecision,
        currentSnapshot: LossFeatureSnapshot
    ): LossMemoryFilterResult {
        if (!LossMemoryConfig.ENABLED) {
            return LossMemoryFilterResult(
                finalDecision = proposedDecision,
                blocked = false,
                bestScore = null,
                matchedRecordId = null,
                message = "Loss memory disabled"
            )
        }

        if (proposedDecision == TradeDecision.HOLD) {
            return LossMemoryFilterResult(
                finalDecision = proposedDecision,
                blocked = false,
                bestScore = null,
                matchedRecordId = null,
                message = "No candidate entry to check"
            )
        }

        return runCatching {
            runCatching { repository.pruneExpired() }
                .onFailure { LossMemoryLogger.w("failed to prune before filtering", it) }

            val records = runCatching { repository.getLossRecords() }
                .getOrElse {
                    LossMemoryLogger.e("failed to load loss records during filtering", it)
                    emptyList()
                }

            LossMemoryLogger.i("loaded ${records.size} records")

            val cutoff = System.currentTimeMillis() - LossMemoryConfig.maxAgeMs()
            val validRecords = records.filter {
                it.pnl < 0.0 &&
                    it.createdAtMs >= cutoff &&
                    it.fingerprintVersion == LossMemoryConfig.FINGERPRINT_VERSION
            }

            if (validRecords.isEmpty()) {
                LossMemoryLogger.i("no valid historical loss records")
                return@runCatching LossMemoryFilterResult(
                    finalDecision = proposedDecision,
                    blocked = false,
                    bestScore = null,
                    matchedRecordId = null,
                    message = "No valid historical loss records"
                )
            }

            val best = validRecords
                .map { record -> record to LossScenarioMatcher.compare(currentSnapshot, record) }
                .maxByOrNull { (_, match) -> match.score }

            if (best == null) {
                return@runCatching LossMemoryFilterResult(
                    finalDecision = proposedDecision,
                    blocked = false,
                    bestScore = null,
                    matchedRecordId = null,
                    message = "No comparable loss-memory records"
                )
            }

            val (record, match) = best
            LossMemoryLogger.i(
                "best match score=${fmt(match.score)} record=${record.id}"
            )

            if (match.matched) {
                LossMemoryLogger.i(
                    "blocked ${proposedDecision.name} due to prior ${record.lossReason.name}"
                )
                LossMemoryFilterResult(
                    finalDecision = TradeDecision.HOLD,
                    blocked = true,
                    bestScore = match.score,
                    matchedRecordId = record.id,
                    message = "Blocked ${proposedDecision.name} due to prior ${record.lossReason.name} score=${fmt(match.score)}"
                )
            } else {
                LossMemoryFilterResult(
                    finalDecision = proposedDecision,
                    blocked = false,
                    bestScore = match.score,
                    matchedRecordId = record.id,
                    message = "Best loss-memory score ${fmt(match.score)} below threshold ${fmt(match.threshold)}"
                )
            }
        }.getOrElse {
            LossMemoryLogger.e("loss memory filter failed; allowing normal flow", it)
            LossMemoryFilterResult(
                finalDecision = proposedDecision,
                blocked = false,
                bestScore = null,
                matchedRecordId = null,
                message = "Loss memory unavailable; pass-through"
            )
        }
    }

    private fun fmt(value: Double): String = String.format(Locale.US, "%.2f", value)
}
