package com.fullpack.panictrader.core

import kotlin.math.abs
import kotlin.math.ln
import kotlin.math.max
import kotlin.math.sqrt

data class FeatureRow(
    val endTimeMs: Long,
    val close: Double,
    val emaFastRel: Double,
    val emaSlowRel: Double,
    val rsi: Double,
    val macdRel: Double,
    val macdSignalRel: Double,
    val macdHistRel: Double,
    val bbPos: Double,
    val bbWidth: Double,
    val atrRel: Double,
    val logRet1: Double,
    val hlPct: Double,
    val ocPct: Double,
    val volZ: Double
)

object Indicators {
    private const val EMA_FAST = 12
    private const val EMA_SLOW = 26
    private const val RSI_N = 14
    private const val MACD_SIGNAL = 9
    private const val BB_N = 20
    private const val BB_MULT = 2.0
    private const val ATR_N = 14
    private const val VOL_Z_N = 200

    fun computeFeatureRows(candles: List<Candle>, intervalMinutes: Int): List<FeatureRow> {
        if (candles.size < 260) return emptyList()

        val closes = candles.map { it.close }.toDoubleArray()
        val opens = candles.map { it.open }.toDoubleArray()
        val highs = candles.map { it.high }.toDoubleArray()
        val lows = candles.map { it.low }.toDoubleArray()
        val vols = candles.map { it.volume }.toDoubleArray()

        val emaFast = ema(closes, EMA_FAST, span = true)
        val emaSlow = ema(closes, EMA_SLOW, span = true)
        val rsi = rsiWilder(closes, RSI_N)

        val macd = DoubleArray(closes.size) { emaFast[it] - emaSlow[it] }
        val macdSignal = ema(macd, MACD_SIGNAL, span = true)
        val macdHist = DoubleArray(closes.size) { macd[it] - macdSignal[it] }

        val (bbMid, bbStd) = rollingMeanStd(closes, BB_N)
        val bbUpper = DoubleArray(closes.size) { bbMid[it] + BB_MULT * bbStd[it] }
        val bbLower = DoubleArray(closes.size) { bbMid[it] - BB_MULT * bbStd[it] }

        val atr = atrWilder(highs, lows, closes, ATR_N)

        val logRet1 = DoubleArray(closes.size) { Double.NaN }
        for (i in 1 until closes.size) logRet1[i] = ln(closes[i] + 1e-12) - ln(closes[i - 1] + 1e-12)

        val hlPct = DoubleArray(closes.size) { i -> (highs[i] - lows[i]) / (closes[i] + 1e-12) }
        val ocPct = DoubleArray(closes.size) { i -> (closes[i] - opens[i]) / (opens[i] + 1e-12) }

        val (volMu, volSd) = rollingMeanStd(vols, VOL_Z_N)
        val volZ = DoubleArray(closes.size) { i ->
            val z = (vols[i] - volMu[i]) / (volSd[i] + 1e-12)
            z.coerceIn(-10.0, 10.0)
        }

        val rows = ArrayList<FeatureRow>(closes.size)
        for (i in closes.indices) {
            val c = closes[i]
            val mid = bbMid[i]
            val upper = bbUpper[i]
            val lower = bbLower[i]

            val bbWidth = ((upper - lower) / (mid + 1e-12)).coerceIn(-10.0, 10.0)
            val bbPos = ((c - lower) / ((upper - lower) + 1e-12)).coerceIn(-5.0, 5.0)

            val row = FeatureRow(
                endTimeMs = candles[i].startTimeMs + intervalMinutes * 60_000L,
                close = c,
                emaFastRel = (emaFast[i] / (c + 1e-12)) - 1.0,
                emaSlowRel = (emaSlow[i] / (c + 1e-12)) - 1.0,
                rsi = rsi[i],
                macdRel = macd[i] / (c + 1e-12),
                macdSignalRel = macdSignal[i] / (c + 1e-12),
                macdHistRel = macdHist[i] / (c + 1e-12),
                bbPos = bbPos,
                bbWidth = bbWidth,
                atrRel = atr[i] / (c + 1e-12),
                logRet1 = logRet1[i],
                hlPct = hlPct[i],
                ocPct = ocPct[i],
                volZ = volZ[i]
            )

            if (isFiniteRow(row)) rows.add(row)
        }
        return rows
    }

    private fun isFiniteRow(r: FeatureRow): Boolean {
        val xs = doubleArrayOf(
            r.emaFastRel, r.emaSlowRel, r.rsi, r.macdRel, r.macdSignalRel, r.macdHistRel,
            r.bbPos, r.bbWidth, r.atrRel, r.logRet1, r.hlPct, r.ocPct, r.volZ
        )
        return xs.all { it.isFinite() }
    }

    private fun ema(x: DoubleArray, n: Int, span: Boolean): DoubleArray {
        val out = DoubleArray(x.size) { Double.NaN }
        if (x.isEmpty()) return out

        val alpha = if (span) 2.0 / (n + 1.0) else 1.0 / n.toDouble()
        var prev = x[0]
        out[0] = prev
        for (i in 1 until x.size) {
            prev = alpha * x[i] + (1.0 - alpha) * prev
            out[i] = prev
        }
        return out
    }

    private fun rsiWilder(close: DoubleArray, n: Int): DoubleArray {
        val out = DoubleArray(close.size) { Double.NaN }
        if (close.size < 2) return out

        val gains = DoubleArray(close.size) { 0.0 }
        val losses = DoubleArray(close.size) { 0.0 }
        for (i in 1 until close.size) {
            val d = close[i] - close[i - 1]
            gains[i] = max(d, 0.0)
            losses[i] = max(-d, 0.0)
        }

        val avgGain = ema(gains, n, span = false)
        val avgLoss = ema(losses, n, span = false)

        for (i in close.indices) {
            val rs = avgGain[i] / (avgLoss[i] + 1e-12)
            out[i] = 100.0 - (100.0 / (1.0 + rs))
        }
        return out
    }

    private fun atrWilder(high: DoubleArray, low: DoubleArray, close: DoubleArray, n: Int): DoubleArray {
        val tr = DoubleArray(close.size) { Double.NaN }
        for (i in close.indices) {
            val hl = high[i] - low[i]
            val prevClose = if (i == 0) close[i] else close[i - 1]
            val hc = abs(high[i] - prevClose)
            val lc = abs(low[i] - prevClose)
            tr[i] = max(hl, max(hc, lc))
        }
        return ema(tr, n, span = false)
    }

    private fun rollingMeanStd(x: DoubleArray, n: Int): Pair<DoubleArray, DoubleArray> {
        val mean = DoubleArray(x.size) { Double.NaN }
        val std = DoubleArray(x.size) { Double.NaN }
        if (n <= 1) return mean to std

        var sum = 0.0
        var sumsq = 0.0

        for (i in x.indices) {
            sum += x[i]
            sumsq += x[i] * x[i]

            if (i >= n) {
                val old = x[i - n]
                sum -= old
                sumsq -= old * old
            }

            if (i >= n - 1) {
                val m = sum / n
                mean[i] = m
                val varPop = max(0.0, (sumsq / n) - (m * m))
                val varSample = if (n > 1) varPop * (n.toDouble() / (n.toDouble() - 1.0)) else varPop
                std[i] = sqrt(varSample)
            }
        }
        return mean to std
    }
}





package com.fullpack.panictrader.core

/**
 * Pure Market Structure computation logic.
 * Detects swing highs and swing lows using a pivot-based method.
 *
 * Requirements:
 * - Detects swing points without future-looking logic (safe for live trading).
 * - Computes structure classification (Bullish, Bearish, Range).
 * - Detects BOS (Break of Structure).
 * - Computes normalized distances to swing points.
 */
data class MarketStructure(
    val isBullishStructure: Boolean,
    val isBearishStructure: Boolean,
    val isRangeStructure: Boolean,
    val distToLastSwingHigh: Double,
    val distToLastSwingLow: Double,
    val bosUp: Boolean,
    val bosDown: Boolean
)

object MarketStructureCalculator {

    fun compute(candles: List<Candle>, pivotSize: Int = 2): MarketStructure {
        // Minimum candles required for at least one pivot point analysis
        if (candles.size < pivotSize * 2 + 1) {
            return neutralStructure()
        }

        val swingHighs = mutableListOf<Double>()
        val swingLows = mutableListOf<Double>()

        // Sliding window to detect pivots.
        // Pivot size of 2 means checking 2 candles left and 2 candles right.
        // Live safety: The loop stops at 'size - pivotSize' so it only considers confirmed pivots.
        for (i in pivotSize until candles.size - pivotSize) {
            val currentHigh = candles[i].high
            val currentLow = candles[i].low

            var isSwingHigh = true
            var isSwingLow = true

            for (j in 1..pivotSize) {
                // Confirm Swing High: No neighbor is higher
                if (candles[i - j].high > currentHigh || candles[i + j].high > currentHigh) {
                    isSwingHigh = false
                }
                // Confirm Swing Low: No neighbor is lower
                if (candles[i - j].low < currentLow || candles[i + j].low < currentLow) {
                    isSwingLow = false
                }
            }

            if (isSwingHigh) swingHighs.add(currentHigh)
            if (isSwingLow) swingLows.add(currentLow)
        }

        // We need at least 2 points to establish a structural trend (e.g., HH + HL)
        if (swingHighs.size < 2 || swingLows.size < 2) {
            return neutralStructure()
        }

        val lastClose = candles.last().close
        val shLast = swingHighs.last()
        val slLast = swingLows.last()
        val shPrev = swingHighs[swingHighs.size - 2]
        val slPrev = swingLows[swingLows.size - 2]

        // Higher High + Higher Low = Bullish
        val bullish = shLast > shPrev && slLast > slPrev
        // Lower High + Lower Low = Bearish
        val bearish = shLast < shPrev && slLast < slPrev
        // Neither = Range
        val range = !bullish && !bearish

        // BOS (Break of Structure): Current price breaks the most recent confirmed swing.
        val bosUp = lastClose > shLast
        val bosDown = lastClose < slLast

        // Distance normalized: (Target - Current) / Current or vice versa.
        // distToLastSwingHigh = (SH - close) / close (positive if below SH)
        // distToLastSwingLow = (close - SL) / close (positive if above SL)
        val distToSH = (shLast - lastClose) / lastClose
        val distToSL = (lastClose - slLast) / lastClose

        return MarketStructure(
            isBullishStructure = bullish,
            isBearishStructure = bearish,
            isRangeStructure = range,
            distToLastSwingHigh = distToSH,
            distToLastSwingLow = distToSL,
            bosUp = bosUp,
            bosDown = bosDown
        )
    }

    private fun neutralStructure() = MarketStructure(
        isBullishStructure = false,
        isBearishStructure = false,
        isRangeStructure = true,
        distToLastSwingHigh = 0.0,
        distToLastSwingLow = 0.0,
        bosUp = false,
        bosDown = false
    )
}








package com.fullpack.panictrader.core

import android.util.Log

/**
 * MarketStructureGate acts as a second confirmation layer.
 * 
 * Rules:
 * - BUY is confirmed ONLY IF structure is bullish AND no BOS occurs AND price is not too close to last swing high.
 * - SELL is confirmed ONLY IF structure is bearish AND no BOS occurs AND price is not too close to last swing low.
 * - All other states (Range, BOS, etc.) convert the decision to HOLD.
 */
class MarketStructureGate(
    private val proposedDecision: TradeDecision,
    private val candles: List<Candle>,
    private val minBoundaryDist: Double = 0.002
) {
    companion object {
        private const val TAG = "MarketStructureGate"
    }

    fun filter(): TradeDecision {
        // If it's already HOLD, no need to check structure.
        if (proposedDecision == TradeDecision.HOLD) return TradeDecision.HOLD

        // 1. Compute Market Structure
        val structure = try {
            MarketStructureCalculator.compute(candles)
        } catch (e: Exception) {
            Log.e(TAG, "Market Structure computation failed: ${e.message}")
            return TradeDecision.HOLD
        }

        val logBase = "[GATE] Proposed: $proposedDecision | Structure: ${if (structure.isBullishStructure) "BULLISH" else if (structure.isBearishStructure) "BEARISH" else "RANGE"}"
        val logDetails = "BOS_U: ${structure.bosUp}, BOS_D: ${structure.bosDown}, distH: ${"%.4f".format(structure.distToLastSwingHigh)}, distL: ${"%.4f".format(structure.distToLastSwingLow)}"

        // 2. Evaluate against gate rules
        val finalDecision = when (proposedDecision) {
            TradeDecision.BUY -> {
                // Confirm BUY: Bullish structure, no active BOS, far enough from Swing High
                if (structure.isBullishStructure && 
                    !structure.bosUp && 
                    !structure.bosDown && 
                    structure.distToLastSwingHigh > minBoundaryDist) {
                    TradeDecision.BUY
                } else {
                    TradeDecision.HOLD
                }
            }
            TradeDecision.SELL -> {
                // Confirm SELL: Bearish structure, no active BOS, far enough from Swing Low
                if (structure.isBearishStructure && 
                    !structure.bosUp && 
                    !structure.bosDown && 
                    structure.distToLastSwingLow > minBoundaryDist) {
                    TradeDecision.SELL
                } else {
                    TradeDecision.HOLD
                }
            }
            else -> TradeDecision.HOLD
        }

        // 3. Logging
        if (finalDecision != proposedDecision) {
            Log.i(TAG, "$logBase -> FILTERED TO HOLD. $logDetails")
        } else {
            Log.i(TAG, "$logBase -> PASSED. $logDetails")
        }

        return finalDecision
    }
}







