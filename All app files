package com.fullpack.panictrader.core.memory

import java.util.Locale
import kotlin.math.abs

object LossScenarioMatcher {

    private data class WeightedComponent(
        val label: String,
        val weight: Double,
        val similarity: Double
    ) {
        val contribution: Double get() = weight * similarity
    }

    fun compare(
        currentSnapshot: LossFeatureSnapshot,
        record: LossScenarioRecord
    ): LossScenarioMatchResult {
        return compareSnapshots(
            currentSnapshot = currentSnapshot,
            pastSnapshot = record.featureSnapshot,
            matchedRecordId = record.id
        )
    }

    fun compareSnapshots(
        currentSnapshot: LossFeatureSnapshot,
        pastSnapshot: LossFeatureSnapshot,
        matchedRecordId: String? = null
    ): LossScenarioMatchResult {
        if (LossMemoryConfig.SYMBOL_STRICT_MATCH && !sameText(currentSnapshot.symbol, pastSnapshot.symbol)) {
            return noMatch("symbol mismatch under strict match", matchedRecordId)
        }
        if (LossMemoryConfig.DECISION_STRICT_MATCH && !sameText(currentSnapshot.decision, pastSnapshot.decision)) {
            return noMatch("decision mismatch under strict match", matchedRecordId)
        }
        if (LossMemoryConfig.REGIME_STRICT_MATCH && !sameText(currentSnapshot.regime, pastSnapshot.regime)) {
            return noMatch("regime mismatch under strict match", matchedRecordId)
        }

        val components = mutableListOf<WeightedComponent>()

        components += WeightedComponent("symbol", 0.10, categoricalSimilarity(currentSnapshot.symbol, pastSnapshot.symbol))
        components += WeightedComponent("decision", 0.10, categoricalSimilarity(currentSnapshot.decision, pastSnapshot.decision))
        components += WeightedComponent("regime", 0.05, categoricalSimilarity(currentSnapshot.regime, pastSnapshot.regime))
        components += WeightedComponent("pBuy", 0.06, numericSimilarity(currentSnapshot.pBuy, pastSnapshot.pBuy, LossMemoryConfig.PROB_TOLERANCE))
        components += WeightedComponent("pSell", 0.06, numericSimilarity(currentSnapshot.pSell, pastSnapshot.pSell, LossMemoryConfig.PROB_TOLERANCE))
        components += WeightedComponent("thresholdUsed", 0.04, numericSimilarity(currentSnapshot.thresholdUsed, pastSnapshot.thresholdUsed, LossMemoryConfig.THRESHOLD_TOLERANCE))
        components += WeightedComponent("vol", 0.05, numericSimilarity(currentSnapshot.vol, pastSnapshot.vol, LossMemoryConfig.VOL_TOLERANCE))
        components += WeightedComponent("adx", 0.05, numericSimilarity(currentSnapshot.adx, pastSnapshot.adx, LossMemoryConfig.ADX_TOLERANCE))
        components += WeightedComponent("diRelation", 0.05, categoricalSimilarity(diRelation(currentSnapshot), diRelation(pastSnapshot)))
        components += WeightedComponent(
            "marketStructure",
            0.10,
            average(
                booleanSimilarity(currentSnapshot.msBullish, pastSnapshot.msBullish),
                booleanSimilarity(currentSnapshot.msBearish, pastSnapshot.msBearish),
                booleanSimilarity(currentSnapshot.msRange, pastSnapshot.msRange)
            )
        )
        components += WeightedComponent(
            "bosState",
            0.05,
            average(
                booleanSimilarity(currentSnapshot.msBosUp, pastSnapshot.msBosUp),
                booleanSimilarity(currentSnapshot.msBosDown, pastSnapshot.msBosDown)
            )
        )
        components += WeightedComponent(
            "swingDistances",
            0.08,
            average(
                numericSimilarity(
                    currentSnapshot.distToLastSwingHigh,
                    pastSnapshot.distToLastSwingHigh,
                    LossMemoryConfig.SWING_DIST_TOLERANCE
                ),
                numericSimilarity(
                    currentSnapshot.distToLastSwingLow,
                    pastSnapshot.distToLastSwingLow,
                    LossMemoryConfig.SWING_DIST_TOLERANCE
                )
            )
        )
        components += WeightedComponent(
            "baseIndicators",
            0.10,
            average(
                numericSimilarity(currentSnapshot.baseAtrRel, pastSnapshot.baseAtrRel, LossMemoryConfig.ATR_TOLERANCE),
                numericSimilarity(currentSnapshot.baseRsi, pastSnapshot.baseRsi, LossMemoryConfig.RSI_TOLERANCE),
                numericSimilarity(currentSnapshot.baseBbWidth, pastSnapshot.baseBbWidth, LossMemoryConfig.BBW_TOLERANCE),
                numericSimilarity(currentSnapshot.baseEmaFastRel, pastSnapshot.baseEmaFastRel, LossMemoryConfig.EMA_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.baseEmaSlowRel, pastSnapshot.baseEmaSlowRel, LossMemoryConfig.EMA_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.baseMacdRel, pastSnapshot.baseMacdRel, LossMemoryConfig.MACD_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.baseMacdSignalRel, pastSnapshot.baseMacdSignalRel, LossMemoryConfig.MACD_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.baseMacdHistRel, pastSnapshot.baseMacdHistRel, LossMemoryConfig.MACD_REL_TOLERANCE)
            )
        )
        components += WeightedComponent(
            "auxIndicators",
            0.11,
            average(
                numericSimilarity(currentSnapshot.auxAtrRel, pastSnapshot.auxAtrRel, LossMemoryConfig.ATR_TOLERANCE),
                numericSimilarity(currentSnapshot.auxRsi, pastSnapshot.auxRsi, LossMemoryConfig.RSI_TOLERANCE),
                numericSimilarity(currentSnapshot.auxBbWidth, pastSnapshot.auxBbWidth, LossMemoryConfig.BBW_TOLERANCE),
                numericSimilarity(currentSnapshot.auxEmaFastRel, pastSnapshot.auxEmaFastRel, LossMemoryConfig.EMA_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.auxEmaSlowRel, pastSnapshot.auxEmaSlowRel, LossMemoryConfig.EMA_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.auxMacdRel, pastSnapshot.auxMacdRel, LossMemoryConfig.MACD_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.auxMacdSignalRel, pastSnapshot.auxMacdSignalRel, LossMemoryConfig.MACD_REL_TOLERANCE),
                numericSimilarity(currentSnapshot.auxMacdHistRel, pastSnapshot.auxMacdHistRel, LossMemoryConfig.MACD_REL_TOLERANCE)
            )
        )

        val score = components.sumOf { it.contribution }.coerceIn(0.0, 1.0)
        val topContributors = components
            .sortedByDescending { it.contribution }
            .take(LossMemoryConfig.TOP_CONTRIBUTORS_LIMIT)
            .map { "${it.label}=${fmt(it.similarity)}" }

        val matched = score >= LossMemoryConfig.SIMILARITY_THRESHOLD
        val reason = if (matched) {
            "score=${fmt(score)} >= ${fmt(LossMemoryConfig.SIMILARITY_THRESHOLD)} via ${topContributors.joinToString()}"
        } else {
            "score=${fmt(score)} < ${fmt(LossMemoryConfig.SIMILARITY_THRESHOLD)}"
        }

        return LossScenarioMatchResult(
            matched = matched,
            score = score,
            threshold = LossMemoryConfig.SIMILARITY_THRESHOLD,
            reason = reason,
            matchedRecordId = matchedRecordId,
            topContributors = topContributors
        )
    }

    private fun noMatch(reason: String, matchedRecordId: String?): LossScenarioMatchResult {
        return LossScenarioMatchResult(
            matched = false,
            score = 0.0,
            threshold = LossMemoryConfig.SIMILARITY_THRESHOLD,
            reason = reason,
            matchedRecordId = matchedRecordId,
            topContributors = emptyList()
        )
    }

    private fun categoricalSimilarity(a: String?, b: String?): Double {
        if (a.isNullOrBlank() && b.isNullOrBlank()) return LossMemoryConfig.NULL_BOTH_SIMILARITY
        if (a.isNullOrBlank() || b.isNullOrBlank()) return 0.0
        return if (sameText(a, b)) 1.0 else 0.0
    }

    private fun booleanSimilarity(a: Boolean?, b: Boolean?): Double {
        if (a == null && b == null) return LossMemoryConfig.NULL_BOTH_SIMILARITY
        if (a == null || b == null) return 0.0
        return if (a == b) 1.0 else 0.0
    }

    private fun numericSimilarity(a: Double?, b: Double?, tolerance: Double): Double {
        if (a == null && b == null) return LossMemoryConfig.NULL_BOTH_SIMILARITY
        if (a == null || b == null) return 0.0
        if (!a.isFinite() || !b.isFinite()) return 0.0
        if (tolerance <= 0.0) return if (a == b) 1.0 else 0.0
        return (1.0 - (abs(a - b) / tolerance)).coerceIn(0.0, 1.0)
    }

    private fun diRelation(snapshot: LossFeatureSnapshot): String {
        val plus = snapshot.plusDi
        val minus = snapshot.minusDi
        if (plus == null || minus == null) return "UNKNOWN"
        return when {
            plus > minus -> "PLUS"
            minus > plus -> "MINUS"
            else -> "FLAT"
        }
    }

    private fun average(vararg values: Double): Double {
        if (values.isEmpty()) return 0.0
        return values.average().coerceIn(0.0, 1.0)
    }

    private fun sameText(a: String, b: String): Boolean = a.equals(b, ignoreCase = true)

