@Composable
fun FlyingBirds() {
    val infiniteTransition = rememberInfiniteTransition()
    val xOffset by infiniteTransition.animateFloat(
        initialValue = -100f, targetValue = 1200f,
        animationSpec = infiniteRepeatable(tween(15000, easing = LinearEasing))
    )
    val wingFlap by infiniteTransition.animateFloat(
        initialValue = -5f, targetValue = 5f,
        animationSpec = infiniteRepeatable(tween(300), RepeatMode.Reverse)
    )

    Canvas(modifier = Modifier.fillMaxSize()) {
        val birdColor = Color.DarkGray.copy(alpha = 0.4f)
        fun drawBird(x: Float, y: Float) {
            val path = Path().apply {
                moveTo(x, y)
                quadraticBezierTo(x + 10.dp.toPx(), y - 10.dp.toPx() + wingFlap.dp.toPx(), x + 20.dp.toPx(), y)
                moveTo(x + 20.dp.toPx(), y)
                quadraticBezierTo(x + 30.dp.toPx(), y - 10.dp.toPx() + wingFlap.dp.toPx(), x + 40.dp.toPx(), y)
            }
            drawPath(path, birdColor, style = Stroke(width = 2.dp.toPx(), cap = StrokeCap.Round))
        }
        drawBird(xOffset, 150.dp.toPx())
        drawBird(xOffset + 50.dp.toPx(), 180.dp.toPx())
        drawBird(xOffset - 30.dp.toPx(), 200.dp.toPx())
    }
}

@Composable
fun ShootingStar() {
    val infiniteTransition = rememberInfiniteTransition()
    val progress by infiniteTransition.animateFloat(
        initialValue = 0f, targetValue = 1f,
        animationSpec = infiniteRepeatable(
            animation = tween(4000, easing = LinearEasing),
            repeatMode = RepeatMode.Restart
        )
    )

    if (progress < 0.2f) {
        Canvas(modifier = Modifier.fillMaxSize()) {
            val startX = size.width * 0.8f
            val startY = size.height * 0.1f
            val distance = 200.dp.toPx()
            val currentX = startX - (progress * 5 * distance)
            val currentY = startY + (progress * 5 * distance * 0.5f)
            
            drawCircle(
                brush = Brush.radialGradient(
                    colors = listOf(Color.White, Color.Transparent),
                    center = Offset(currentX, currentY),
                    radius = 5.dp.toPx()
                ),
                radius = 5.dp.toPx(),
                center = Offset(currentX, currentY)
            )
            
            drawLine(
                color = Color.White.copy(alpha = 1f - progress * 5),
                start = Offset(currentX, currentY),
                end = Offset(currentX + 40.dp.toPx(), currentY - 20.dp.toPx()),
                strokeWidth = 2.dp.toPx(),
                cap = StrokeCap.Round
            )
        }
    }
}

