data class LoadedBundle(
    val policy: PolicyV9,
    val norm: NormJson,
    val modelFile: File
)

class ModelBundleManager(private val context: Context) {
    private val json = Json { ignoreUnknownKeys = true }

    private val bundleRoot = File(context.filesDir, "bundles")
    private val defaultDir = File(bundleRoot, "default")
    private val importedDir = File(bundleRoot, "imported")

    private var currentDir: File = defaultDir

    fun useDefaultBundle() {
        currentDir = defaultDir
    }

    fun ensureDefaultBundle() {
        if (!defaultDir.exists()) defaultDir.mkdirs()
        copyAssetIfMissing("bundles/default/policy_v9.json", File(defaultDir, "policy_v9.json"))
        copyAssetIfMissing("bundles/default/norm.json", File(defaultDir, "norm.json"))
        copyAssetIfMissing("bundles/default/model.tflite", File(defaultDir, "model.tflite"))
    }

    fun describeCurrent(): String {
        val p = File(currentDir, "policy_v9.json")
        val n = File(currentDir, "norm.json")
        val m = File(currentDir, "model.tflite")
        return "dir=${currentDir.name} | policy=${p.exists()} | norm=${n.exists()} | model=${m.exists()}"
    }

    fun isBundleReady(): Boolean {
        return File(currentDir, "policy_v9.json").exists()
                && File(currentDir, "norm.json").exists()
                && File(currentDir, "model.tflite").exists()
    }

    fun loadBundle(): LoadedBundle {
        val policyText = File(currentDir, "policy_v9.json").readText()
        val normText = File(currentDir, "norm.json").readText()
        val policy = json.decodeFromString(PolicyV9.serializer(), policyText)
        val norm = json.decodeFromString(NormJson.serializer(), normText)
        val modelFile = File(currentDir, "model.tflite")

        require(modelFile.exists()) { "model.tflite missing in bundle" }
        require(norm.featureCols.size == norm.mean.size && norm.mean.size == norm.std.size) {
            "norm.json arrays must match feature_cols length"
        }
        return LoadedBundle(policy, norm, modelFile)
    }

    suspend fun importPolicy(uri: Uri) {
        val dir = ensureImportedDir()
        copyFromUri(uri, File(dir, "policy_v9.json"))
        currentDir = dir
    }

    suspend fun importNorm(uri: Uri) {
        val dir = ensureImportedDir()
        copyFromUri(uri, File(dir, "norm.json"))
        currentDir = dir
    }

    suspend fun importModel(uri: Uri) {
        val dir = ensureImportedDir()
        copyFromUri(uri, File(dir, "model.tflite"))
        currentDir = dir
    }

    private fun ensureImportedDir(): File {
        if (!importedDir.exists()) importedDir.mkdirs()
        val latestDir = File(importedDir, "latest")
        if (!latestDir.exists()) latestDir.mkdirs()
        return latestDir
    }

    private fun copyAssetIfMissing(assetPath: String, outFile: File) {
        if (outFile.exists()) return
        runCatching {
            context.assets.open(assetPath).use { input ->
                outFile.outputStream().use { output -> input.copyTo(output) }
            }
        }
    }

    private fun copyFromUri(uri: Uri, outFile: File) {
        context.contentResolver.openInputStream(uri)?.use { input ->
            outFile.outputStream().use { output -> input.copyTo(output) }
        } ?: error("Cannot open uri: $uri")
    }
}








